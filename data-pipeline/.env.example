# Copy to .env and fill in. .env is gitignored — never commit real keys.

# API-Football (api-football.com) — DEV/TRIAL ONLY.
# Build-time accuracy comparison; NOT a publish source (ToS denies publication
# rights — see SOURCING.md). Rotate this key before any public deploy.
API_FOOTBALL_KEY=your-key-here

# --- Reel ingest (npm run reel) — a MANUAL, LOCAL task. See build/reel.ts. ---
# Path to a Netscape-format cookies.txt for a (burner) Instagram account,
# authorised for pulling reels shared with permission. Never put this in CI.
IG_COOKIES=/absolute/path/to/cookies.txt

# R2 target for reel videos. Defaults match the worldcup-2026 bucket; override
# only if the bucket / public URL changes. Needs wrangler auth with R2 write
# (wrangler login, or CLOUDFLARE_API_TOKEN with R2 Object R/W on the bucket).
# R2_BUCKET=worldcup-2026
# R2_PREFIX=post-media
# R2_PUBLIC_BASE=https://pub-53b6937ac1564b65a7bb62986f6253ce.r2.dev
