# deps
node_modules/

# secrets — API keys live here, NEVER committed (rotate before any are shared)
.env
.env.*
!.env.example

# Rebuildable artifacts — NOT committed (see V1-PLAN.md).
# The SQLite warehouse is a binary that mutates every refresh; committing it
# bloats git history. It is regenerated by `npm run build:warehouse` and
# mirrored to R2 when shared.
warehouse/*.db
warehouse/*.db-journal
warehouse/*.db-wal
warehouse/*.db-shm

# Raw fetched source data — large/refetchable; snapshot to R2 for reproducibility.
sources/

# Generated banners — binary output; push to R2 when wiring to the site.
banners/out/

# The exported JSON slices ARE committed (text, diffs cleanly) — see warehouse/export/.
!warehouse/export/
