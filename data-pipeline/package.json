{
  "name": "worldcup-2026-data-pipeline",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Data-engineering pipeline: fetch free WC2026 sources, link into a SQLite warehouse, derive H2H + tiers, export JSON. Separate from the Astro site.",
  "scripts": {
    "fetch": "tsx fetch/index.ts",
    "build:warehouse": "tsx build/index.ts",
    "export": "tsx build/export.ts",
    "banners": "tsx banners/generate.ts",
    "banners:blog": "tsx banners/blog.ts",
    "banners:thumbs": "tsx banners/thumbs.ts",
    "preview": "tsx articles/preview.ts",
    "flags": "tsx fetch/flags.ts",
    "flags:figma": "tsx fetch/figmaflags.ts",
    "all": "npm run fetch && npm run build:warehouse && npm run export",
    "publish:d1": "tsx build/publish-d1.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4"
  }
}
