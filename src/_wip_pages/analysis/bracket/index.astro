---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import { provider } from '../../../lib/provider';

// Only the Round of 32 ties are confirmed at the snapshot; later rounds are TBD
// until results come in. Render the confirmed ties and placeholder columns.
const r32 = provider.getFixtures().filter((m) => m.stage === 'r32');
const getTeam = (id: string) => provider.getTeam(id)!;

const rounds = ['Round of 32', 'Round of 16', 'Quarter-finals', 'Semi-finals', 'Final'];
---

<AnalysisLayout
  title="Knockout Bracket — World Cup 2026 Analysis"
  description="The 2026 World Cup knockout bracket: confirmed Round of 32 ties and the path to the final at MetLife Stadium on 19 July."
  active="bracket"
>
  <h1 class="mb-1 text-2xl font-bold">Knockout bracket</h1>
  <p class="mb-4 text-[13.5px] text-[var(--muted)]">
    Confirmed Round of 32 ties. Later rounds fill in as results come through.
  </p>

  <div class="flex gap-6 overflow-x-auto pb-4">
    <div class="flex min-w-[210px] flex-col gap-3">
      <h4 class="text-[12px] uppercase tracking-wide text-[var(--muted)]">{rounds[0]}</h4>
      {r32.map((m) => {
        const h = getTeam(m.homeTeamId);
        const a = getTeam(m.awayTeamId);
        return (
          <a
            href={`/analysis/predict/?a=${h.id}&b=${a.id}`}
            class="rounded-lg border border-[var(--line)] bg-[var(--panel)] px-3 py-2 text-[13px] hover:border-[var(--accent)]"
          >
            <div class="flex justify-between gap-2">
              <span>{h.name}</span>
            </div>
            <div class="flex justify-between gap-2 text-[var(--muted)]">
              <span>{a.name}</span>
            </div>
          </a>
        );
      })}
    </div>

    {rounds.slice(1).map((label) => (
      <div class="flex min-w-[210px] flex-col gap-3">
        <h4 class="text-[12px] uppercase tracking-wide text-[var(--muted)]">{label}</h4>
        <div
          class="rounded-lg border border-dashed border-[var(--line)] px-3 py-2 text-[13px] text-[var(--muted)]"
        >
          To be decided
        </div>
      </div>
    ))}
  </div>
</AnalysisLayout>
