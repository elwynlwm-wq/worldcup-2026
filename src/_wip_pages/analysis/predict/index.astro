---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import Predictor from '../../../components/analysis/Predictor.tsx';
import { getPredictorTeams } from '../../../lib/predictorData';
import { getH2HByTeam } from '../../../lib/warehouse';

// This page is pre-rendered static. The optional ?a=&b= matchup in deep links
// is read client-side by the island (query params aren't known at build time).
const teams = getPredictorTeams();
// All-time H2H for every pairing, so the island can show any matchup's record
// client-side. ~25KB gzipped; H2H aggregates are public data.
const h2hByTeam = getH2HByTeam();
---

<AnalysisLayout
  title="Match Predictor — World Cup 2026 Analysis"
  description="Pick any two of the 48 World Cup 2026 teams and see a live forecast: win/draw/lose probability and the rating factors behind it, from a transparent Elo model."
  active="predict"
>
  <h1 class="mb-1 text-2xl font-bold">Match predictor</h1>
  <p class="mb-4 text-[13.5px] text-[var(--muted)]">
    Pick any two teams. The forecast updates live, computed from the same model the rest of the
    site uses.
  </p>

  <Predictor client:load teams={teams} h2hByTeam={h2hByTeam} />
</AnalysisLayout>
