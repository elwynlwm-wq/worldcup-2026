---
// Community CTA — dark panel with pitch motif + gold button, from the Claude
// Design. Two copy variants: 'story' (bottom of articles) and 'match' (bottom of
// upcoming match pages). Links out to the community site (SportifyLive).
interface Props {
  variant?: 'story' | 'match';
  href?: string;
}
// Default through /go for conversion tracking; override href if needed.
const { variant = 'story', href = '/go/sportify-chat' } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
const copy = variant === 'match'
  ? {
      title: 'Got a call on this one? Stake your claim.',
      body: "Lock in your prediction, back up your hot take, and climb the tipsters' table. The sharpest reads — and the boldest calls — rise to the top.",
    }
  : {
      title: 'Got a take on this one?',
      body: 'Join the community to post your prediction, argue it out with other fans, and see who actually called the result.',
    };
---

<a
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
  class="kb-card-hover relative mt-[22px] block overflow-hidden rounded-[18px] px-7 py-6 text-white" style="background:#16181d">
  <div class="pointer-events-none absolute -right-[20px] -top-[30px] h-[210px] w-[230px] opacity-50" style="background:url('/assets/pitch.svg') no-repeat center/contain"></div>
  <div class="relative z-[2]">
    <div class="font-display text-[11px] font-extrabold uppercase tracking-[1.4px]" style="color:var(--color-gold)">World Cup Analytics community</div>
    <div class="font-display mb-1.5 mt-2 max-w-[520px] text-[23px] font-black tracking-[-.5px] text-balance">{copy.title}</div>
    <div class="max-w-[540px] text-[15.5px] leading-[1.45]" style="font-family:var(--font-serif);opacity:.9">{copy.body}</div>
    <span class="font-display mt-4 inline-flex items-center gap-1.5 rounded-[11px] px-[18px] py-[11px] text-[14px] font-extrabold" style="background:var(--color-gold);color:#16181d">Join the community →</span>
  </div>
</a>
