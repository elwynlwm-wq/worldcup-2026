---
// Small marker-sketch accents drawn straight on the page (no card, no tape) —
// the whiteboard style applied to page headers. Decoration only, aria-hidden.
// Hidden on small screens where the margin doesn't exist.
interface Props {
  variant: 'ball' | 'whistle' | 'clock' | 'star' | 'pencil' | 'arrow';
  class?: string;
}
const { variant, class: cls = '' } = Astro.props;
---

<span class={`pointer-events-none hidden select-none sm:block ${cls}`} aria-hidden="true">
  {variant === 'ball' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(8deg)">
      <circle cx="32" cy="32" r="22" fill="none" stroke="var(--color-night)" stroke-width="2.5" />
      <polygon points="32,24 39.6,29.5 36.7,38.4 27.3,38.4 24.4,29.5" fill="none" stroke="var(--color-night)" stroke-width="2.2" stroke-linejoin="round" />
      <path d="M32 24 V13 M39.6 29.5 L50 26 M36.7 38.4 L43 47 M27.3 38.4 L21 47 M24.4 29.5 L14 26" stroke="var(--color-night)" stroke-width="2" stroke-linecap="round" />
      <path d="M46 12 q6 3 7 10" fill="none" stroke="var(--color-gold)" stroke-width="2.5" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'whistle' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(-7deg)">
      <path d="M14 26 h26 v6 a13 13 0 1 1 -26 0 Z" fill="none" stroke="var(--color-night)" stroke-width="2.5" stroke-linejoin="round" />
      <circle cx="27" cy="36" r="4" fill="none" stroke="var(--color-night)" stroke-width="2" />
      <path d="M44 24 l8 -6 M46 30 l10 -2 M42 19 l4 -8" stroke="var(--color-clay)" stroke-width="2.5" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'clock' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(6deg)">
      <circle cx="32" cy="34" r="19" fill="none" stroke="var(--color-night)" stroke-width="2.5" />
      <path d="M32 34 V22 M32 34 h10" stroke="var(--color-royal)" stroke-width="2.5" stroke-linecap="round" />
      <path d="M18 17 a9 9 0 0 1 9 -5 M46 17 a9 9 0 0 0 -9 -5" fill="none" stroke="var(--color-gold)" stroke-width="2.5" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'star' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(-8deg)">
      <polygon points="32,10 38.5,25 54,26.5 42,37 45.5,53 32,44.5 18.5,53 22,37 10,26.5 25.5,25"
        fill="var(--color-gold)" stroke="var(--color-night)" stroke-width="2.2" stroke-linejoin="round" opacity=".9" />
      <path d="M8 14 l5 3 M56 12 l-5 4" stroke="var(--color-ink-3)" stroke-width="2" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'pencil' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(10deg)">
      <path d="M18 46 L40 14 l8 6 L26 52 l-10 2 Z" fill="none" stroke="var(--color-night)" stroke-width="2.4" stroke-linejoin="round" />
      <path d="M36 20 l8 6" stroke="var(--color-night)" stroke-width="2" />
      <path d="M12 56 q8 -3 16 0 q6 2 12 -1" fill="none" stroke="var(--color-royal)" stroke-width="2.5" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'arrow' && (
    <svg width="64" height="64" viewBox="0 0 64 64" style="transform:rotate(-4deg)">
      <path d="M10 48 Q28 44 36 30 Q42 20 40 12" fill="none" stroke="var(--color-clay)" stroke-width="2.6" stroke-dasharray="6 5" stroke-linecap="round" />
      <path d="M34 15 L40 10 L44 17" fill="none" stroke="var(--color-clay)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M46 44 l3 3 M49 44 l-3 3" stroke="var(--color-night)" stroke-width="2" stroke-linecap="round" />
    </svg>
  )}
</span>
