---
// Branded "Full Time" scorecard — cover + in-article infographic for post-match
// analytics. Built from real data: score, flags, scorers, minutes. Dark card
// that pops inside the light theme, echoing a broadcast full-time graphic.
import Flag from './Flag.astro';
import { provider } from '../lib/provider';

interface Scorer { side: 'home' | 'away'; scorer: string; minute: string | number; pen?: boolean }
interface Props {
  home: string; away: string;
  homeScore: number; awayScore: number;
  scorers?: Scorer[];
  stage?: string; date?: string; venue?: string;
  headline?: string; pens?: string;
}
const { home, away, homeScore, awayScore, scorers = [], stage, date, venue, headline, pens } = Astro.props;
const hName = provider.getTeam(home)?.name ?? home;
const aName = provider.getTeam(away)?.name ?? away;
const homeG = scorers.filter((s) => s.side === 'home');
const awayG = scorers.filter((s) => s.side === 'away');
---
<figure style="margin:0 0 24px;border-radius:20px;overflow:hidden;background:var(--color-night);color:#fff;padding:24px 22px;box-shadow:0 12px 34px rgba(0,0,0,.20)">
  {headline && (
    <div style="font-family:var(--font-display);font-weight:900;font-size:clamp(26px,5.2vw,42px);line-height:.98;color:var(--color-gold);letter-spacing:-1px">{headline}</div>
  )}
  <div style="font-family:var(--font-display);font-weight:800;font-size:12px;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.55);margin:6px 0 16px">Full time</div>
  <div style="display:flex;align-items:center;justify-content:center;gap:16px">
    <div style="display:flex;flex-direction:column;align-items:center;gap:9px;flex:1;min-width:0">
      <Flag team={home} shape="circle" w={54} />
      <span style="font-family:var(--font-display);font-weight:800;font-size:14px;text-align:center">{hName}</span>
    </div>
    <div style="font-family:var(--font-display);font-weight:900;font-size:46px;letter-spacing:-1px;white-space:nowrap">{homeScore}<span style="opacity:.45;margin:0 9px">–</span>{awayScore}</div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:9px;flex:1;min-width:0">
      <Flag team={away} shape="circle" w={54} />
      <span style="font-family:var(--font-display);font-weight:800;font-size:14px;text-align:center">{aName}</span>
    </div>
  </div>
  {pens && (
    <div style="text-align:center;margin-top:12px;font-family:var(--font-display);font-weight:800;font-size:13px;color:var(--color-gold)">{pens}</div>
  )}
  {(homeG.length > 0 || awayG.length > 0) && (
    <div style="display:flex;justify-content:space-between;gap:16px;margin-top:18px;border-top:1px solid rgba(255,255,255,.14);padding-top:13px;font-size:13px">
      <div style="flex:1">{homeG.map((g) => (<div style="color:rgba(255,255,255,.85);margin:2px 0"><b style="color:#fff">{g.minute}'</b> {g.scorer}{g.pen ? ' (pen)' : ''}</div>))}</div>
      <div style="flex:1;text-align:right">{awayG.map((g) => (<div style="color:rgba(255,255,255,.85);margin:2px 0">{g.scorer}{g.pen ? ' (pen)' : ''} <b style="color:#fff">{g.minute}'</b></div>))}</div>
    </div>
  )}
  {(stage || date || venue) && (
    <div style="text-align:center;margin-top:16px;font-size:11.5px;color:rgba(255,255,255,.5);font-family:var(--font-display);font-weight:700;text-transform:uppercase;letter-spacing:.08em">{[stage, date, venue].filter(Boolean).join(' · ')}</div>
  )}
</figure>
