---
// Upcoming-match graphic — a reusable A-vs-B hero.
//
// One neutral line-art frame (public/banners/matchup-frame.png, monochrome ink
// on cream, no text/colour/bar) is reused for EVERY pairing; this component
// tints the two halves with each team's real colours and draws all the precise,
// data-driven bits on top in CSS: flags, short codes, names, VS, the kickoff
// label and the who-wins vote bar. So the art is generic but the result is
// specific to the matchup. See _matchmock.astro for the original concept.
//
// Used on the home "Today" hero and the /h2h/<a>-vs-<b> hero.
import Flag from './Flag.astro';
import { teamColors } from '../data/teamColors';
import type { Team } from '../lib/model';

interface Props {
  home: Team;
  away: Team;
  /** who-wins split (0–100, should sum ~100). Fan votes if we have them, else model. */
  vote: { home: number; draw: number; away: number };
  /** small line above: e.g. "Round of 32 · 30 Jun · NRG Stadium" */
  label?: string;
  /** source caption under the bar: "Fan vote" | "Our forecast" */
  voteSource?: string;
  href?: string;
  class?: string;
}
const { home, away, vote: rawVote, label, voteSource = 'Our forecast', href, class: cls = '' } = Astro.props;
const hc = teamColors(home.id);
const ac = teamColors(away.id);
const Tag = href ? 'a' : 'div';

// Normalize to percentages — callers may pass raw vote COUNTS (SofaScore) or
// already-percentages (the model). Either way we display a clean 0–100 split.
const total = rawVote.home + rawVote.draw + rawVote.away || 1;
const homePct = Math.round((rawVote.home / total) * 100);
const awayPct = Math.round((rawVote.away / total) * 100);
const drawPct = Math.max(0, 100 - homePct - awayPct);
const vote = { home: homePct, draw: drawPct, away: awayPct };
---

<Tag
  {...(href ? { href } : {})}
  class:list={['relative block h-fit self-start overflow-hidden rounded-[18px]', href && 'kb-card-hover', cls]}
  style="aspect-ratio:21/9;background:var(--color-bg)"
>
  {/* Street-Fighter split: two hard-edged diagonal halves, each filled with the
      team's own banner art, meeting at an angled seam. clip-path makes the edge
      crisp; a team-colour gradient on top keeps identity strong + text legible. */}
  <div class="absolute inset-0" style={`clip-path:polygon(0 0, 58% 0, 42% 100%, 0 100%);background:linear-gradient(135deg, ${hc.c1} 0%, ${hc.c2} 100%)`}>
    <div class="absolute inset-0" style={`background-image:url(/banners/${home.id}.png);background-size:cover;background-position:left center`}></div>
    <div class="absolute inset-0" style={`background:linear-gradient(120deg, ${hc.c1}d9 0%, ${hc.c1}59 70%, transparent 100%)`}></div>
  </div>
  <div class="absolute inset-0" style={`clip-path:polygon(58% 0, 100% 0, 100% 100%, 42% 100%);background:linear-gradient(225deg, ${ac.c1} 0%, ${ac.c2} 100%)`}>
    <div class="absolute inset-0" style={`background-image:url(/banners/${away.id}.png);background-size:cover;background-position:right center`}></div>
    <div class="absolute inset-0" style={`background:linear-gradient(240deg, ${ac.c1}d9 0%, ${ac.c1}59 70%, transparent 100%)`}></div>
  </div>

  {/* glowing energy seam — clipped to the SAME 58%→42% diagonal as the colour
      split so it always lines up with the banner edge (no fixed skew angle). */}
  <div class="absolute inset-0" style="clip-path:polygon(55% 0, 61% 0, 45% 100%, 39% 100%);background:linear-gradient(90deg, transparent, var(--color-gold), transparent);filter:blur(5px);mix-blend-mode:screen"></div>
  <div class="absolute inset-0" style="clip-path:polygon(57.6% 0, 58.4% 0, 42.4% 100%, 41.6% 100%);background:rgba(255,255,255,.95);box-shadow:0 0 14px 2px var(--color-gold)"></div>

  {/* top: kickoff / stage label */}
  {label && (
    <div class="font-display absolute left-1/2 top-[7%] z-[3] -translate-x-1/2 whitespace-nowrap text-[clamp(8px,1.25vw,12px)] font-extrabold uppercase tracking-[2px] text-white" style="text-shadow:0 1px 5px rgba(0,0,0,.55)">{label}</div>
  )}

  {/* center: flags + short codes + names + single VS */}
  <div class="absolute inset-0 z-[2] flex items-center justify-between px-[6%] pt-[3%]">
    <div class="flex w-[30%] flex-col items-center gap-1.5 text-white">
      <Flag team={home.id} w={58} />
      <div class="font-display text-[clamp(15px,3vw,30px)] font-black leading-none" style="text-shadow:0 2px 8px rgba(0,0,0,.5)">{home.shortCode}</div>
      <div class="text-[clamp(8px,1.2vw,12.5px)] font-bold leading-tight" style="text-shadow:0 1px 5px rgba(0,0,0,.55);opacity:.95">{home.name}</div>
    </div>
    <div class="font-display text-[clamp(22px,4.2vw,46px)] font-black italic text-white" style="text-shadow:0 2px 10px rgba(0,0,0,.45)">VS</div>
    <div class="flex w-[30%] flex-col items-center gap-1.5 text-white">
      <Flag team={away.id} w={58} />
      <div class="font-display text-[clamp(15px,3vw,30px)] font-black leading-none" style="text-shadow:0 2px 8px rgba(0,0,0,.5)">{away.shortCode}</div>
      <div class="text-[clamp(8px,1.2vw,12.5px)] font-bold leading-tight" style="text-shadow:0 1px 5px rgba(0,0,0,.55);opacity:.95">{away.name}</div>
    </div>
  </div>

  {/* bottom: who-wins vote bar */}
  <div class="absolute bottom-[7%] left-1/2 z-[2] w-[62%] -translate-x-1/2">
    <div class="mb-1 flex items-end justify-between text-[clamp(8px,1.1vw,12px)] font-extrabold text-white" style="text-shadow:0 1px 5px rgba(0,0,0,.55)">
      <span>{home.shortCode} {vote.home}%</span>
      <span class="text-[clamp(7px,.95vw,10px)] uppercase tracking-[1.5px]" style="opacity:.8">{voteSource}</span>
      <span>{vote.away}% {away.shortCode}</span>
    </div>
    <div class="flex h-[8px] overflow-hidden rounded-full" style="box-shadow:inset 0 0 0 1px rgba(255,255,255,.35)">
      <span style={`width:${vote.home}%;background:#fff`}></span>
      <span style={`width:${vote.draw}%;background:rgba(255,255,255,.3)`}></span>
      <span style={`width:${vote.away}%;background:rgba(255,255,255,.65)`}></span>
    </div>
  </div>
</Tag>
