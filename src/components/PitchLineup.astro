---
// Pitch-view lineup — ported from the design (match lineups section). A 3D-tilted
// pitch with jersey SVG markers, laid out by FORMATION (we parse e.g. "4-3-3"
// into rows since we store position not grid coords). Static.
import type { Team } from '../lib/model';
import type { SsLineup } from '../lib/warehouse';
import { teamColors } from '../data/teamColors';

interface Props {
  team: Team;
  lineup: SsLineup;
}
const { team, lineup } = Astro.props;
const { c1, c2 } = teamColors(team.id);

// Build rows from formation. GK is its own back row; outfield rows from "4-3-3".
const starters = lineup.starters.slice(0, 11);
const gk = starters.find((p) => p.pos === 'G') ?? starters[0];
const outfield = starters.filter((p) => p !== gk);

const formationRows = (lineup.formation || '4-3-3').split('-').map((n) => parseInt(n, 10)).filter((n) => n > 0);
// distribute outfield players into the formation rows (defenders → forwards)
const rows: typeof outfield[] = [];
let idx = 0;
for (const count of formationRows) {
  rows.push(outfield.slice(idx, idx + count));
  idx += count;
}
// any leftover (mismatch) → last row
if (idx < outfield.length) rows.push(outfield.slice(idx));

// y positions: GK near bottom (~90%), rows spread up the pitch
const nRows = rows.length;
const place = (rowIdx: number, count: number, colIdx: number) => {
  // y: GK at 90, top row at ~16
  const y = 90 - ((rowIdx + 1) / (nRows + 1)) * 74;
  const x = ((colIdx + 1) / (count + 1)) * 100;
  return { x, y };
};

interface Marker { name: string; number: string; x: number; y: number; fill: string; numColor: string }
const markers: Marker[] = [];
// GK
markers.push({ name: gk.name.split(' ').slice(-1)[0], number: gk.jersey ?? '1', x: 50, y: 90, fill: '#ffffff', numColor: '#16181d' });
rows.forEach((row, ri) => {
  row.forEach((p, ci) => {
    const { x, y } = place(ri, row.length, ci);
    markers.push({ name: p.name.split(' ').slice(-1)[0], number: p.jersey ?? '', x, y, fill: c1, numColor: '#ffffff' });
  });
});
---

<div style="perspective:1150px;max-width:440px;margin:6px auto 0;padding-top:42px">
  <div style="position:relative;width:100%;aspect-ratio:3/4;transform:rotateX(40deg);transform-style:preserve-3d;transform-origin:center 56%">
    {/* pitch */}
    <div style="position:absolute;inset:0;border-radius:16px;overflow:hidden;background:linear-gradient(180deg,#1d212b 0%,#14171e 100%);border:1px solid #2a2e38;box-shadow:0 22px 40px -18px rgba(0,0,0,.7)">
      <div style="position:absolute;inset:0;background:repeating-linear-gradient(180deg,rgba(255,255,255,.022) 0 9%,transparent 9% 18%)"></div>
      <div style="position:absolute;left:10px;right:10px;top:10px;bottom:10px;border:1.5px solid rgba(255,255,255,.18);border-radius:8px"></div>
      <div style="position:absolute;left:10px;right:10px;top:50%;height:1.5px;background:rgba(255,255,255,.18)"></div>
      <div style="position:absolute;left:50%;top:50%;width:84px;height:84px;border:1.5px solid rgba(255,255,255,.18);border-radius:50%;transform:translate(-50%,-50%)"></div>
      <div style="position:absolute;left:50%;top:50%;width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.32);transform:translate(-50%,-50%)"></div>
      <div style="position:absolute;left:50%;top:10px;transform:translateX(-50%);width:50%;height:12%;border:1.5px solid rgba(255,255,255,.16);border-top:none;border-radius:0 0 6px 6px"></div>
      <div style="position:absolute;left:50%;bottom:10px;transform:translateX(-50%);width:50%;height:12%;border:1.5px solid rgba(255,255,255,.16);border-bottom:none;border-radius:6px 6px 0 0"></div>
    </div>
    {/* markers */}
    {markers.map((m) => (
      <span style={`position:absolute;left:${m.x}%;top:${m.y}%;transform:translate(-50%,-100%) rotateX(-40deg);transform-origin:bottom center;transform-style:preserve-3d;width:80px;display:flex;flex-direction:column;align-items:center;gap:3px;text-align:center`}>
        <span style="position:relative;width:42px;height:38px;filter:drop-shadow(0 4px 5px rgba(0,0,0,.6))">
          <svg viewBox="0 0 64 56" style="width:100%;height:100%;display:block"><path d="M20 6 L6 13 L11 25 L19 22 L19 50 L45 50 L45 22 L53 25 L58 13 L44 6 C44 12 38 15 32 15 C26 15 20 12 20 6 Z" fill={m.fill} stroke="rgba(255,255,255,.92)" stroke-width="2.5" stroke-linejoin="round"></path></svg>
          <span style={`position:absolute;left:0;right:0;top:48%;transform:translateY(-50%);font-family:var(--font-display);font-weight:900;font-size:14px;color:${m.numColor};text-shadow:0 1px 2px rgba(0,0,0,.45)`}>{m.number}</span>
        </span>
        <span style="font-size:10px;font-weight:800;font-family:var(--font-display);color:#fff;background:rgba(0,0,0,.62);padding:2px 6px;border-radius:4px;line-height:1.1;white-space:nowrap">{m.name}</span>
      </span>
    ))}
  </div>
</div>
