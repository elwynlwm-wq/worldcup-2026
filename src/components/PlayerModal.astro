---
// PlayerModal — one per page, built pixel-faithfully from the Claude Design
// player-modal mockup. Opens when any element carrying a data-player JSON payload
// is clicked (squad cards, star lists, players index, search). Built client-side
// from that payload so the site stays static (no page per player). Real country
// flags are swapped in for the design's CSS-gradient placeholders.
---

<div id="player-modal" class="km-scrim" style="display:none">
  <div id="player-modal-card" class="km-card">
    <button id="player-modal-close" class="km-close" aria-label="Close">✕</button>
    <div id="player-modal-inner"></div>
  </div>
</div>

<style is:global>
  .km-scrim { position:fixed; inset:0; z-index:90; background:rgba(16,18,24,.55); backdrop-filter:blur(3px); display:flex; align-items:center; justify-content:center; padding:20px; animation:km-fade .18s ease both; color:#16181d; }
  .km-card { position:relative; width:100%; max-width:470px; max-height:88vh; display:flex; flex-direction:column; background:#fff; border-radius:20px; overflow:hidden; box-shadow:0 30px 60px -20px rgba(0,0,0,.55); animation:km-pop .22s ease both; }
  .km-close { position:absolute; top:14px; right:14px; z-index:3; border:none; cursor:pointer; width:30px; height:30px; border-radius:9px; background:rgba(255,255,255,.16); color:#fff; font:16px/1 var(--font-display); }
  .km-head { position:relative; flex:none; overflow:hidden; padding:24px; color:#fff; background:#16181d; }
  .km-head__pitch { position:absolute; top:-30px; right:-30px; width:200px; height:200px; background:url('/assets/pitch.svg') no-repeat center/contain; opacity:.5; pointer-events:none; }
  .km-head__row { position:relative; z-index:2; display:flex; align-items:center; gap:16px; }
  .km-avatar { position:relative; flex:none; }
  .km-avatar img, .km-avatar .km-ph { width:84px; height:84px; border-radius:50%; object-fit:cover; object-position:center top; border:3px solid var(--pos,#b23b2e); background:#e7e2d4; display:block; }
  .km-avatar .km-ph { display:flex; align-items:center; justify-content:center; font:800 28px var(--font-display); color:var(--pos,#b23b2e); }
  .km-shirt { position:absolute; bottom:-3px; right:-3px; min-width:26px; height:26px; padding:0 6px; border-radius:8px; background:#f3b50a; color:#16181d; border:2px solid #16181d; display:flex; align-items:center; justify-content:center; font:900 13px var(--font-display); }
  .km-id { min-width:0; flex:1; }
  .km-pos { display:inline-flex; align-items:center; gap:7px; margin-bottom:5px; }
  .km-pos__chip { font:800 10.5px var(--font-display); color:#fff; background:var(--pos,#b23b2e); padding:3px 8px; border-radius:6px; }
  .km-pos__label { font-size:12px; color:#a59a85; font-weight:600; }
  .km-name { font:900 24px/1.04 var(--font-display); letter-spacing:-.6px; }
  .km-meta { display:flex; align-items:center; gap:8px; margin-top:6px; flex-wrap:wrap; }
  .km-team { cursor:pointer; display:inline-flex; align-items:center; gap:6px; }
  .km-flag { width:22px; height:15px; border-radius:3px; object-fit:cover; box-shadow:inset 0 0 0 1px rgba(255,255,255,.3); }
  .km-team b { font-size:13px; color:#f3b50a; }
  .km-club { font-size:12.5px; color:#a59a85; }
  .km-tiers { display:flex; gap:6px; margin-top:9px; flex-wrap:wrap; }
  .km-tier { font:800 10.5px var(--font-display); letter-spacing:.3px; padding:3px 9px; border-radius:999px; }
  .km-body { overflow-y:auto; padding:18px 22px 20px; }
  .km-sec { font:800 11px var(--font-display); letter-spacing:1px; text-transform:uppercase; color:#a59a85; }
  .km-kpis { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:10px; }
  .km-kpi { background:#faf6ee; border:1px solid #eee6d8; border-radius:13px; padding:13px 14px; }
  .km-kpi b { display:block; font:900 23px var(--font-display); letter-spacing:-.5px; }
  .km-kpi span { color:#6f6655; font-size:12px; font-weight:600; }
  .km-wc { display:flex; align-items:baseline; justify-content:space-between; margin:20px 0 10px; }
  .km-wc__tot { font-size:12px; color:#6f6655; font-weight:700; }
  .km-log { border:1px solid #e9e1d2; border-radius:13px; overflow:hidden; }
  .km-log__head, .km-log__row { display:flex; align-items:center; padding:10px 13px; }
  .km-log__head { padding:8px 13px; background:#faf6ee; border-bottom:1px solid #f1ebdf; font:800 10px var(--font-display); letter-spacing:.5px; text-transform:uppercase; color:#a59a85; }
  .km-log__row { border-bottom:1px solid #f4eee1; }
  .km-log__row:last-child { border-bottom:none; }
  .km-c-match { flex:1; display:flex; align-items:center; gap:7px; min-width:0; }
  .km-c-match b { font-size:13px; } .km-c-match .km-date { font-size:11px; color:#b3a890; }
  .km-c-stage { width:58px; text-align:center; font-size:11.5px; font-weight:700; color:#6f6655; }
  .km-c-min { width:40px; text-align:center; font-size:12.5px; font-variant-numeric:tabular-nums; }
  .km-c-ga { width:58px; text-align:center; font-size:12px; font-weight:700; }
  .km-c-rtg { width:38px; text-align:right; display:flex; justify-content:flex-end; }
  .km-rtg { font:800 12px var(--font-display); color:#fff; padding:2px 6px; border-radius:6px; }
  .km-note { margin-top:14px; color:#a59a85; font-size:11.5px; line-height:1.45; }
  @keyframes km-fade { from { opacity:0 } to { opacity:1 } }
  @keyframes km-pop { from { transform:scale(.85); opacity:0 } to { transform:scale(1); opacity:1 } }
</style>

<script is:inline>
  (() => {
    const overlay = document.getElementById('player-modal');
    const inner = document.getElementById('player-modal-inner');
    const card = document.getElementById('player-modal-card');
    if (!overlay || !inner || !card) return;

    const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const flagUrl = (slug) => `/flags-country/${slug}.svg`;
    const POS_COLOR = { GK: '#e0a200', DF: '#5b6470', MF: '#1f7a4d', FW: '#b23b2e' };
    const STAGE = { group: 'Group', r32: 'R32', r16: 'R16', qf: 'QF', sf: 'SF', final: 'Final', third_place: '3rd' };
    const fmtDate = (iso) => { try { return new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)); } catch { return ''; } };
    // tier badge palette (text / bg)
    const TIER_BADGE = {
      Elite: ['#8a6d00', '#fbf0cf'],
      Strong: ['#1f3fbf', '#eaeefb'], Established: ['#1f3fbf', '#eaeefb'],
      Solid: ['#1f7a4d', '#e6f2eb'], Squad: ['#1f7a4d', '#e6f2eb'],
      Modest: ['#8a7f6a', '#efeadd'], Prospect: ['#8a7f6a', '#efeadd'], Lower: ['#8a7f6a', '#efeadd'],
    };
    const tierChip = (label, prefix) => {
      if (!label) return '';
      const [c, bg] = TIER_BADGE[label] || ['#8a7f6a', '#efeadd'];
      return `<span class="km-tier" style="color:${c};background:${bg}">${prefix ? prefix + ' · ' : ''}${esc(label)}</span>`;
    };
    const ratingColor = (r) => { const n = parseFloat(r); return n >= 7.5 ? '#1f7a4d' : n >= 6.8 ? '#9a8e74' : '#b23b2e'; };

    function avatar(d) {
      if (d.photo) return `<img src="${esc(d.photo)}" alt="${esc(d.name)}" />`;
      const initials = d.name.split(' ').filter(Boolean).map((w) => w[0]).slice(0, 2).join('').toUpperCase();
      return `<span class="km-ph">${initials}</span>`;
    }

    function render(d) {
      const pos = POS_COLOR[d.pos] || '#5b6470';
      card.style.setProperty('--pos', pos);
      const ageLabel = d.age ? ` · ${d.age} yrs` : '';

      let log = '';
      if (d.wc && d.wc.matches.length) {
        const rows = d.wc.matches.map((m) =>
          `<div class="km-log__row">
            <span class="km-c-match"><img class="km-flag" src="${flagUrl(m.opp)}" alt="" /><b>vs ${esc(m.oppCode)}</b><span class="km-date">${esc(fmtDate(m.date))}</span></span>
            <span class="km-c-stage">${esc(STAGE[m.stage] || m.stage)}</span>
            <span class="km-c-min">${m.minutes ?? 0}'</span>
            <span class="km-c-ga">${m.goals ?? 0}G · ${m.assists ?? 0}A</span>
            <span class="km-c-rtg">${m.rating ? `<span class="km-rtg" style="background:${ratingColor(m.rating)}">${esc(m.rating)}</span>` : '<span style="color:#b3a890;font-size:12px">–</span>'}</span>
          </div>`).join('');
        log = `
          <div class="km-wc">
            <div class="km-sec">This World Cup</div>
            <div class="km-wc__tot">${d.wc.apps} app${d.wc.apps === 1 ? '' : 's'} · ${d.wc.mins}' · ${d.wc.goals}G ${d.wc.assists}A</div>
          </div>
          <div class="km-log">
            <div class="km-log__head"><span class="km-c-match">Match</span><span class="km-c-stage">Stage</span><span class="km-c-min">Min</span><span class="km-c-ga">G/A</span><span class="km-c-rtg">Rtg</span></div>
            ${rows}
          </div>`;
      } else {
        log = `<div class="km-wc"><div class="km-sec">This World Cup</div><div class="km-wc__tot">No minutes yet</div></div>`;
      }

      inner.innerHTML = `
        <header class="km-head">
          <div class="km-head__pitch"></div>
          <div class="km-head__row">
            <div class="km-avatar">${avatar(d)}</div>
            <div class="km-id">
              <div class="km-pos"><span class="km-pos__chip">${esc(d.pos)}</span><span class="km-pos__label">${esc(d.posName)}${ageLabel}</span></div>
              <div class="km-name">${esc(d.name)}</div>
              <div class="km-meta">
                <a class="km-team" href="/teams/${esc(d.teamId)}/"><img class="km-flag" src="${flagUrl(d.teamId)}" alt="" /><b>${esc(d.teamName)}</b></a>
                ${d.club ? `<span class="km-club">· ${esc(d.club)}</span>` : ''}
              </div>
              <div class="km-tiers">${tierChip(d.playerTier, '')}${tierChip(d.clubTier, 'Club')}</div>
            </div>
          </div>
        </header>
        <div class="km-body">
          <div class="km-sec">International career</div>
          <div class="km-kpis">
            <div class="km-kpi"><b>${esc(d.caps)}</b><span>Caps</span></div>
            <div class="km-kpi"><b>${esc(d.goals)}</b><span>Goals</span></div>
            <div class="km-kpi"><b>${esc(d.goalsPerCap)}</b><span>Goals / cap</span></div>
          </div>
          ${log}
          <p class="km-note">International caps &amp; goals are real career totals. Per-match tournament figures — minutes, goals, ratings — come from API-Football as the tournament unfolds.</p>
        </div>`;
    }

    function open(payload) {
      let d; try { d = JSON.parse(payload); } catch { return; }
      render(d);
      overlay.style.display = 'flex';
      const body = document.querySelector('.km-body'); if (body) body.scrollTop = 0;
      document.body.style.overflow = 'hidden';
    }
    function close() { overlay.style.display = 'none'; document.body.style.overflow = ''; }

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('[data-player]');
      if (trigger) { e.preventDefault(); open(trigger.getAttribute('data-player')); }
    });
    document.getElementById('player-modal-close').addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  })();
</script>
