---
// Centralized SEO <head> for every page: title, meta, canonical, Open Graph,
// Twitter card, and JSON-LD structured data. One place so nothing is forgotten.
// See docs/seo.md.

interface Props {
  title: string;
  description: string;
  /** Path or absolute URL of the social image. Falls back to the default. */
  image?: string;
  /** "website" for pages, "article" for posts. */
  type?: 'website' | 'article';
  /** Override the canonical URL; defaults to the current page URL. */
  canonical?: string;
  /** Keep this page out of the index (e.g. drafts/utility pages). */
  noindex?: boolean;
  /** JSON-LD structured data object(s). Templated by the caller per page type. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Article-specific metadata, used when type === 'article'. */
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  canonical,
  noindex = false,
  jsonLd,
  publishDate,
  updatedDate,
  author,
} = Astro.props;

const SITE_NAME = 'World Cup Analytics';

// A colleague deploys this repo to his own Vercel; that copy must NOT be
// indexed (avoid a second crawlable site competing with production). Vercel sets
// VERCEL=1 at build time, so any Vercel build auto-noindexes. Our production
// build (GitHub Actions → wrangler → Cloudflare Pages) and local dev are
// unaffected. Canonical still points to the CF `site` regardless.
const onVercel = process.env.VERCEL === '1';
const robotsNoindex = noindex || onVercel;

// Resolve canonical + image to absolute URLs against the configured `site`.
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL.href} />
{robotsNoindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={imageURL.href} />
{type === 'article' && publishDate && (
  <meta property="article:published_time" content={publishDate.toISOString()} />
)}
{type === 'article' && updatedDate && (
  <meta property="article:modified_time" content={updatedDate.toISOString()} />
)}
{type === 'article' && author && <meta property="article:author" content={author} />}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL.href} />

{/* Structured data (JSON-LD) */}
{jsonLdArray.map((data) => (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
))}
