---
// Showdown panel — ported from ShowdownPanel.dc.html. Big tappable team picks
// (engagement, NOT a gate — the forecast shows regardless), a fan bar + "our
// model backs X" reveal, the forecast bar, and the "what's behind it" factor
// table. Pick state is client-side (localStorage), the rest is static.
import type { Team } from '../lib/model';
import { predict } from '../lib/model';
import { getTeamPlayers } from '../lib/warehouse';
import { provider } from '../lib/provider';
import Flag from './Flag.astro';
import Avatar from './analysis/Avatar.astro';
import { playerTriggerAttrs } from '../lib/playerModal';

interface Props {
  home: Team;
  away: Team;
  /** fan vote counts (SofaScore), already oriented home/away */
  fans?: { home: number; away: number } | null;
  /** which slice to render — the H2H page splits the panel across tabs.
   *  prediction = poll + forecast (the interactive bit);
   *  insights   = forecast + "what's behind it" factors + star men;
   *  full       = everything (default, e.g. the standalone predictor). */
  mode?: 'prediction' | 'insights' | 'full';
  /** true once the match has kicked off — the poll/fan bar is the frozen
   *  pre-match snapshot, so we label it rather than invite voting. */
  frozen?: boolean;
}
const { home, away, fans = null, mode = 'full', frozen = false } = Astro.props;

const showPoll = mode !== 'insights';
const showFactors = mode !== 'prediction';
const showStars = mode !== 'prediction';

const pr = predict(home, away);
const pct = (x: number) => Math.round(x * 100);
const fav = pr.win >= pr.lose ? home : away;
const modelPick = pr.win >= pr.lose ? 'home' : 'away';
const sign = (v: number) => (v > 0 ? '+' : '') + v;

// star men to watch (insights) — top scorers per side, with pos/club + photo
const POSNAME: Record<string, string> = { GK: 'GK', DF: 'DF', MF: 'MF', FW: 'FW' };
const starsFor = (teamId: string) =>
  provider.getSquad(teamId).slice().sort((a, b) => b.goals - a.goals).slice(0, 3);
const photoFor = (() => {
  const all = [...getTeamPlayers(home.id), ...getTeamPlayers(away.id)];
  const byName = new Map(all.map((p) => [p.name, p.photo]));
  return (name: string) => byName.get(name) ?? null;
})();

const fanTotal = fans ? fans.home + fans.away : 0;
const fanHomePct = fanTotal ? Math.round((fans!.home / fanTotal) * 100) : null;
// Read-only fans view: which side the crowd backs (no voting). 'home'|'away'|null.
const fansPick = fanHomePct == null ? null : fanHomePct >= 50 ? 'home' : 'away';

// factor table — the model breakdown, row by row. Green = the better value.
// The last row ("Our rating") is the adjusted rating the forecast runs on:
// Elo + form + squad + home boost.
const factors: { label: string; sub: string; h: string | number; a: string | number; hWin: boolean; total?: boolean }[] = [
  { label: 'Team rating', sub: 'Elo — rises by beating strong teams', h: home.elo, a: away.elo, hWin: home.elo >= away.elo },
  { label: 'World ranking', sub: 'Official FIFA rank', h: '#' + home.fifaRank, a: '#' + away.fifaRank, hWin: home.fifaRank <= away.fifaRank },
  { label: 'Form so far', sub: "How they've played this tournament", h: sign(home.formAdj), a: sign(away.formAdj), hWin: home.formAdj >= away.formAdj },
  { label: 'Squad firepower', sub: 'Goals in the squad vs the field', h: sign(home.squadAdj), a: sign(away.squadAdj), hWin: home.squadAdj >= away.squadAdj },
  { label: 'Home boost', sub: 'Edge for the three host nations', h: sign(home.hostAdj), a: sign(away.hostAdj), hWin: home.hostAdj >= away.hostAdj },
  { label: 'Our rating', sub: 'Everything above, combined', h: home.adjRating, a: away.adjRating, hWin: home.adjRating >= away.adjRating, total: true },
];
const matchKey = [home.id, away.id].sort().join('|');
---

<div class="mt-5" data-showdown data-home={home.id} data-away={away.id} data-key={matchKey}>
  {showPoll && (
  <>
  {/* WHO FANS ARE BACKING — read-only: real SofaScore split + our model pick. */}
  <div class="rounded-[18px] p-5 text-white" style="background:var(--color-night)">
    <div class="font-display text-center text-[15px] font-black tracking-wide">WHO FANS ARE BACKING</div>
    <div class="mb-3.5 text-center text-[13px]" style="color:var(--color-ink-3)">
      {frozen ? 'How the crowd called it, frozen at kick-off.' : 'The crowd’s call — and how our model compares.'}
    </div>
    <div class="flex items-stretch gap-3">
      {(['home', 'away'] as const).map((side) => {
        const t = side === 'home' ? home : away;
        const pctSide = fanHomePct == null ? null : side === 'home' ? fanHomePct : 100 - fanHomePct;
        const isPick = fansPick === side;
        return (
          <div
            class="flex flex-1 items-center justify-center gap-2.5 rounded-[12px] px-4 py-3 text-center text-white"
            style={`border:2.5px solid ${isPick ? 'var(--color-gold)' : 'rgba(255,255,255,.12)'};background:#22252e`}
          >
            <Flag team={t.id} w={34} class="flex-none border-2 border-white/70 shadow-[0_3px_8px_-2px_rgba(0,0,0,.5)]" />
            <span class="min-w-0">
              <span class="font-display block text-[15px] font-extrabold leading-tight" style="text-shadow:0 1px 4px rgba(0,0,0,.55)">{t.name}</span>
              <span class="block text-[11.5px] font-bold" style="opacity:.9;text-shadow:0 1px 3px rgba(0,0,0,.5)">
                {pctSide == null ? '—' : isPick ? `Fans’ pick · ${pctSide}%` : `${pctSide}%`}
              </span>
            </span>
          </div>
        );
      })}
    </div>

    {fanHomePct != null && (
      <div class="mt-[18px]">
        <div class="mb-1.5 flex justify-between text-[12px] font-bold">
          <span>Fans: {home.shortCode} {fanHomePct}%</span><span>{away.shortCode} {100 - fanHomePct}%</span>
        </div>
        <div class="flex h-3 overflow-hidden rounded-[7px]" style="background:#2a2d36">
          <span style={`width:${fanHomePct}%;background:var(--color-gold)`}></span><span style="flex:1;background:#5b6472"></span>
        </div>
      </div>
    )}

    {/* our model pick — always shown, no gating */}
    <div class="mt-4 flex items-center gap-3 rounded-[12px] p-3.5" style="background:#22252e">
      <div class="flex h-10 w-10 flex-none items-center justify-center rounded-[10px]" style="background:var(--color-royal)">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><circle cx="12" cy="12" r="3.2"/><path d="M6 8.5l3 3.5-3 3.5" stroke="#f3b50a"/></svg>
      </div>
      <div class="flex-1">
        <div class="font-display text-[14px] font-extrabold">Our model backs <span style="color:var(--color-gold)">{(modelPick === 'home' ? home : away).name}</span></div>
        {fansPick != null && (
          <div class="mt-0.5 text-[12.5px]" style="color:var(--color-ink-3)">
            {fansPick === modelPick ? 'The crowd agrees with the model.' : 'The crowd is leaning the other way.'}
          </div>
        )}
      </div>
    </div>
  </div>
  </>
  )}

  {/* FORECAST — shown in both prediction and insights */}
  <h2 class="font-display mt-[26px] mb-1 text-[21px] font-extrabold">{fav.name} are favoured</h2>
  <p class="mb-3 text-[14.5px]" style="color:var(--color-ink-2)">{fav.name} have about a {pct(Math.max(pr.win, pr.lose))}% chance of winning in 90 minutes.</p>
  <div class="font-display flex h-[34px] overflow-hidden rounded-[10px] text-[13px] font-extrabold">
    <div class="flex min-w-[30px] items-center justify-center text-white" style={`width:${pct(pr.win)}%;background:var(--color-royal)`}>{pct(pr.win)}</div>
    <div class="flex min-w-[30px] items-center justify-center" style={`width:${pct(pr.draw)}%;background:#e7dfce;color:var(--color-ink-2)`}>{pct(pr.draw)}</div>
    <div class="flex min-w-[30px] items-center justify-center text-white" style={`width:${pct(pr.lose)}%;background:#2b2e36`}>{pct(pr.lose)}</div>
  </div>
  <div class="mt-1.5 flex justify-between text-[11.5px] font-bold" style="color:var(--color-ink-3)">
    <span>{home.shortCode} win</span><span>draw</span><span>{away.shortCode} win</span>
  </div>

  {showFactors && (
  <>
  {/* WHAT'S BEHIND IT */}
  <h2 class="font-display mt-[26px] mb-3 text-[21px] font-extrabold">What's behind it</h2>
  <div class="overflow-hidden rounded-[16px] border" style="background:var(--color-surface);border-color:var(--color-line-2)">
    <div class="flex items-center border-b px-4 py-2.5" style="border-color:var(--color-surface-3);background:var(--color-surface-2)">
      <span class="font-display w-[54px] flex-none text-center text-[13px] font-extrabold">{home.shortCode}</span>
      <span class="flex-1 text-center text-[11px] font-bold uppercase tracking-wide" style="color:var(--color-ink-3)">Factor</span>
      <span class="font-display w-[54px] flex-none text-center text-[13px] font-extrabold">{away.shortCode}</span>
    </div>
    {factors.map((f) => (
      <div class="flex items-center border-b px-4 py-2.5" style="border-color:var(--color-surface-3)">
        <span class="font-display w-[54px] flex-none text-center text-[15px] font-extrabold" style={`color:${f.hWin ? '#0d6b46' : 'var(--color-ink-4)'}`}>{f.h}</span>
        <span class="flex-1 text-center"><b class="text-[13.5px]">{f.label}</b><div class="mt-px text-[11.5px]" style="color:var(--color-ink-3)">{f.sub}</div></span>
        <span class="font-display w-[54px] flex-none text-center text-[15px] font-extrabold" style={`color:${!f.hWin ? '#0d6b46' : 'var(--color-ink-4)'}`}>{f.a}</span>
      </div>
    ))}
  </div>
  <p class="mt-3 text-[13px] leading-relaxed" style="color:var(--color-ink-3)">
    Win probability from the Elo expected score on the adjusted rating, with a draw term that shrinks as the gap grows. A transparent heuristic — not betting advice.
  </p>
  </>
  )}

  {showStars && (
  <>
  {/* STAR MEN TO WATCH */}
  <h2 class="font-display mt-[26px] mb-3 text-[21px] font-extrabold">Star men to watch</h2>
  <div class="grid grid-cols-1 items-start gap-4 sm:grid-cols-2">
    {[home, away].map((t) => (
      <div>
        <div class="mb-2.5 flex items-center gap-2"><Flag team={t.id} w={26} /><b class="text-[14px]">{t.name}</b></div>
        <div class="flex flex-col gap-2">
          {starsFor(t.id).map((p) => (
            <button {...playerTriggerAttrs(p)} class="kb-card-hover flex w-full cursor-pointer items-center gap-2.5 rounded-[11px] border px-3 py-2.5 text-left" style="background:var(--color-surface);border-color:var(--color-line-2)">
              <Avatar name={p.name} position={p.pos} photo={photoFor(p.name)} size={34} />
              <span class="font-display flex-none rounded-md px-1.5 py-0.5 text-[10px] font-extrabold text-white" style={`background:${p.pos === 'GK' ? '#e0a200' : p.pos === 'DF' ? '#5b6470' : p.pos === 'MF' ? '#1f7a4d' : '#b23b2e'}`}>{POSNAME[p.pos] ?? p.pos}</span>
              <span class="min-w-0 flex-1"><b class="block truncate text-[13px]">{p.name}</b><span class="text-[11px]" style="color:var(--color-ink-3)">{p.club}</span></span>
              <span class="font-display flex-none text-[13px] font-extrabold" style="color:var(--color-royal)">{p.goals}G</span>
            </button>
          ))}
        </div>
      </div>
    ))}
  </div>
  </>
  )}
</div>
