---
// The one shared site shell header — Kickabout brand. Used by every layout so
// the blog and analysis zones stop looking like two different websites.
interface Props { active?: string }
const { active = '' } = Astro.props;
const items: [string, string, string][] = [
  ['/', 'Home', ''],
  ['/analysis', 'Analysis', 'analysis'],
  ['/articles', 'Stories', 'articles'],
];
---
<header class="sticky top-0 z-30 border-b border-line bg-bg/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center gap-5 px-4 py-3.5">
    <a href="/" class="flex items-center gap-2.5 font-display text-[22px] font-black tracking-tight">
      <svg class="h-6 w-6 shrink-0" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="15" fill="#f6f4ee"></circle>
        <path d="M16 5.4l6.4 4.7-2.45 7.5h-7.9l-2.45-7.5z" fill="#15171c"></path>
        <g fill="none" stroke="#15171c" stroke-width="1.5">
          <path d="M16 5.4V1.4"></path><path d="M22.4 10.1l4.5-2.2"></path>
          <path d="M19.95 17.6l4.6 3M12.05 17.6l-4.6 3"></path><path d="M9.6 10.1L5.1 7.9"></path>
        </g>
        <circle cx="16" cy="16" r="15" fill="none" stroke="#15171c" stroke-width="1.3"></circle>
      </svg>
      <span>Kick<span class="text-ball">about</span></span>
    </a>
    <nav class="flex flex-1 gap-1">
      {items.map(([href, label, key]) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-3 py-1.5 text-sm font-semibold',
            active === key ? 'bg-ink text-bg' : 'text-muted hover:text-ink',
          ]}
        >{label}</a>
      ))}
    </nav>
  </div>
</header>
