---
// A simple content-library component, droppable into MDX:
//   <StatCallout label="Win probability" value="23%" />
// Build static components like this for prose embellishments; reach for a
// Preact island only when something genuinely needs interactivity.
// See docs/content-authoring.md.
interface Props {
  label: string;
  value: string;
  hint?: string;
}
const { label, value, hint } = Astro.props;
---

<div
  class="not-prose my-6 rounded-xl border p-5"
  style="border-color:var(--color-line);background:var(--color-panel)"
>
  <div class="text-sm font-semibold uppercase tracking-wide" style="color:var(--color-ink-muted)">
    {label}
  </div>
  <div class="font-display mt-1 text-3xl font-black" style="color:var(--color-ball)">{value}</div>
  {hint && <div class="mt-1 text-sm" style="color:var(--color-ink-dim)">{hint}</div>}
</div>
