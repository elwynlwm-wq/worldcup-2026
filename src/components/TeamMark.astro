---
// Two-tone diagonal national mark. Trademark-free, tiny, zero image load.
import { teamColors } from '../data/teamColors';
interface Props { id: string; size?: number }
const { id, size = 34 } = Astro.props;
const [c1, c2] = teamColors(id);
---
<span
  class="inline-block shrink-0 rounded-[7px]"
  style={`width:${size}px;height:${size}px;background:linear-gradient(135deg,${c1} 0 50%,${c2} 50% 100%);box-shadow:inset 0 0 0 1px rgba(255,255,255,.14)`}
  aria-hidden="true"
></span>
