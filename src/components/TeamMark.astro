---
// Two-tone diagonal team mark — the dense-context team identifier (lists, cards,
// fixtures). Flags are used instead in 1–2-team contexts (team/match pages).
// Colours from src/data/teamColors. Pure CSS, zero image load.
import { teamGrad } from '../data/teamColors';

interface Props {
  team: string; // slug
  w?: number;
  h?: number;
  class?: string;
}
const { team, w = 26, h = 19, class: cls = '' } = Astro.props;
---

<span
  class:list={['inline-block flex-none', cls]}
  style={`width:${w}px;height:${h}px;border-radius:4px;background:${teamGrad(team)};box-shadow:inset 0 0 0 1px rgba(0,0,0,.14)`}
  aria-hidden="true"
></span>
