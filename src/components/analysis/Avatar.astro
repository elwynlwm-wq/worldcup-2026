---
// Player avatar: real photo (API-Football) when available, else position-tinted
// initials. Position colours align to the World Cup Analytics palette. Light theme.
interface Props {
  name: string;
  position?: string;
  photo?: string | null;
  size?: number;
}
const { name, position = '', photo = null, size = 46 } = Astro.props;

const initials = name
  .split(' ')
  .filter(Boolean)
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

// Accept both GK/DF/MF/FW and SofaScore's G/D/M/F.
const posKey = (position || '').toUpperCase().replace(/^(G|D|M|F)$/, (m) =>
  ({ G: 'GK', D: 'DF', M: 'MF', F: 'FW' })[m]!,
);
const tint: Record<string, string> = {
  GK: 'var(--color-gold)',
  DF: 'var(--color-royal)',
  MF: 'var(--color-pitch)',
  FW: 'var(--color-clay)',
};
const ring = tint[posKey] ?? 'var(--color-ink-3)';
const px = `${size}px`;
---

{photo ? (
  <img
    src={photo}
    alt={name}
    loading="lazy"
    width={size}
    height={size}
    class="flex-none rounded-full object-cover object-top"
    style={`width:${px};height:${px};border:2px solid ${ring};background:var(--color-bg)`}
  />
) : (
  <span
    aria-hidden="true"
    class="flex flex-none items-center justify-center rounded-full font-bold"
    style={`width:${px};height:${px};font-size:${Math.round(size * 0.34)}px;background:var(--color-bg);color:${ring};border:2px solid ${ring}`}
  >
    {initials}
  </span>
)}
