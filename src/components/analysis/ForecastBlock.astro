---
// The full forecast explainer for a matchup: probability bar, the factor
// breakdown table, and key players. Ported from the prototype's predictionBlock.
import type { Team } from '../../lib/model';
import { predict } from '../../lib/model';
import { provider } from '../../lib/provider';
import ProbBar from './ProbBar.astro';

interface Props {
  home: Team;
  away: Team;
}
const { home, away } = Astro.props;
const pr = predict(home, away);
const pct = (x: number) => Math.round(x * 100);
const fav = pr.win >= pr.lose ? home : away;
const favp = Math.max(pr.win, pr.lose);
const sign = (v: number) => (v > 0 ? '+' : '') + v;

const rows: [string, string | number, string | number][] = [
  ['Elo rating', home.elo, away.elo],
  ['FIFA rank', '#' + home.fifaRank, '#' + away.fifaRank],
  ['Tournament form', sign(home.formAdj), sign(away.formAdj)],
  ['Squad attack', sign(home.squadAdj), sign(away.squadAdj)],
  ['Home advantage', sign(home.hostAdj), sign(away.hostAdj)],
  ['Adjusted rating', home.adjRating, away.adjRating],
];

const keyPlayers = (t: Team) =>
  provider
    .getSquad(t.id)
    .slice()
    .sort((x, y) => y.goals - x.goals)
    .slice(0, 3);
---

<h2 class="mt-6 mb-2 text-lg font-bold">Forecast</h2>
<p class="text-[13.5px] text-[var(--muted)]">
  <b class="text-[var(--text)]">{fav.name} favoured</b> · {pct(favp)}% to win in 90 minutes
</p>
<ProbBar home={home} away={away} pr={pr} />

<h2 class="mt-6 mb-2 text-lg font-bold">What's behind it</h2>
<table class="w-full border-collapse text-[13.5px]">
  <thead>
    <tr class="text-[12px] uppercase tracking-wide text-[var(--muted)]">
      <th class="border-b border-[var(--line)] px-2.5 py-2 text-right">{home.shortCode}</th>
      <th class="border-b border-[var(--line)] px-2.5 py-2 text-center">factor</th>
      <th class="border-b border-[var(--line)] px-2.5 py-2 text-right">{away.shortCode}</th>
    </tr>
  </thead>
  <tbody>
    {rows.map(([label, hv, av]) => (
      <tr>
        <td class="border-b border-[var(--line)] px-2.5 py-2 text-right font-bold tabular-nums">
          {hv}
        </td>
        <td class="border-b border-[var(--line)] px-2.5 py-2 text-center text-[var(--muted)]">
          {label}
        </td>
        <td class="border-b border-[var(--line)] px-2.5 py-2 text-right font-bold tabular-nums">
          {av}
        </td>
      </tr>
    ))}
  </tbody>
</table>
<p class="mt-2 text-[13.5px] text-[var(--muted)]">
  Win probability from the Elo expected score on adjusted ratings, with a draw term that shrinks
  as the gap grows. Transparent heuristic, not betting advice.
</p>

<h2 class="mt-6 mb-2 text-lg font-bold">Key players to watch</h2>
<div class="grid grid-cols-2 items-start gap-3">
  {[home, away].map((t) => (
    <div class="grid gap-2">
      {keyPlayers(t).map((p) => (
        <div class="rounded-xl border border-[var(--line)] bg-[var(--panel)] px-3 py-2">
          <div class="font-semibold">{p.name}</div>
          <div class="text-[11px] text-[var(--muted)]">
            {p.pos} · {p.club} · {p.goals} intl goals
          </div>
        </div>
      ))}
    </div>
  ))}
</div>
