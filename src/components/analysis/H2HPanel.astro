---
// All-time head-to-head panel for two WC nations. Reads one matchup's record
// from the warehouse (build-time). Renders nothing if they've never met.
import type { Team } from '../../lib/model';
import { getH2H } from '../../lib/warehouse';

interface Props {
  home: Team;
  away: Team;
}
const { home, away } = Astro.props;
const rec = getH2H(home.id, away.id);

const fmtDate = (iso: string) => {
  if (!iso) return '';
  const d = new Date(iso);
  return Number.isNaN(d.valueOf())
    ? iso
    : new Intl.DateTimeFormat('en', { dateStyle: 'medium' }).format(d);
};

// Width % for the result bar (guard against divide-by-zero).
const pct = (n: number) => (rec && rec.played ? Math.round((n / rec.played) * 100) : 0);
---

{rec && (
  <section class="mt-6">
    <h2 class="mb-1 text-lg font-bold">All-time head-to-head</h2>
    <p class="text-[13.5px] text-[var(--muted)]">
      {home.name} and {away.name} have met <b class="text-[var(--text)]">{rec.played}</b> times
      {rec.lastMeeting && <> · last on {fmtDate(rec.lastMeeting)}</>}.
    </p>

    <div class="my-3 flex h-[30px] overflow-hidden rounded-lg text-xs font-extrabold">
      <div
        class="flex min-w-[28px] items-center justify-center bg-[var(--accent)] text-[#04130b]"
        style={`width:${pct(rec.aWins)}%`}
        title={`${home.name} wins`}
      >
        {rec.aWins}
      </div>
      <div
        class="flex min-w-[28px] items-center justify-center bg-[var(--panel2)] text-[var(--muted)]"
        style={`width:${pct(rec.draws)}%`}
        title="draws"
      >
        {rec.draws}
      </div>
      <div
        class="flex min-w-[28px] items-center justify-center bg-[var(--accent2)] text-[#04130b]"
        style={`width:${pct(rec.bWins)}%`}
        title={`${away.name} wins`}
      >
        {rec.bWins}
      </div>
    </div>
    <div class="flex justify-between text-[11px] text-[var(--muted)]">
      <span>{home.shortCode} {rec.aWins} W</span>
      <span>{rec.draws} D</span>
      <span>{rec.bWins} W {away.shortCode}</span>
    </div>

    <p class="mt-2 text-[13.5px] text-[var(--muted)]">
      Goals all-time: {home.shortCode} {rec.aGoals} – {rec.bGoals} {away.shortCode}.
    </p>
  </section>
)}
