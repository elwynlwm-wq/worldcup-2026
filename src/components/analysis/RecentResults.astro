---
// Recent finished WC matches — from the fresh API-Football feed (live source).
// Build-time; static HTML.
import { provider } from '../../lib/provider';
import { getRecentResults } from '../../lib/warehouse';

const results = getRecentResults(6);
const teamName = (id: string) => provider.getTeam(id)?.name ?? id;

const stageLabel: Record<string, string> = {
  group: 'Group stage',
  r32: 'Round of 32',
  r16: 'Round of 16',
  qf: 'Quarter-final',
  sf: 'Semi-final',
  third_place: 'Third place',
  final: 'Final',
};
const fmtDate = (iso: string) =>
  new Intl.DateTimeFormat('en', { dateStyle: 'medium' }).format(new Date(iso));
---

{results.length > 0 && (
  <section>
    <h2 class="mt-8 mb-2 text-lg font-bold">Recent results</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      {results.map((m) => (
        <div class="rounded-xl border border-[var(--line)] bg-[var(--panel)] p-3.5">
          <div class="flex items-center justify-between font-semibold">
            <span>{teamName(m.homeTeamId)}</span>
            <span class="tabular-nums text-[var(--accent)]">
              {m.homeScore} – {m.awayScore}
            </span>
            <span class="text-right">{teamName(m.awayTeamId)}</span>
          </div>
          <div class="mt-1 text-[11px] text-[var(--muted)]">
            {stageLabel[m.stage] ?? m.stage} · {fmtDate(m.date)}
            {m.venue ? ` · ${m.venue}` : ''}
          </div>
        </div>
      ))}
    </div>
  </section>
)}
