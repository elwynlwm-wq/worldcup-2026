---
// Analysis zone shell. Now shares the site-wide Kickabout header (via SiteHeader)
// and Kickabout tokens, with a secondary sub-nav for the analysis sections.
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description: string;
  active?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, active = '', canonical, jsonLd } = Astro.props;

const NAV: [string, string][] = [
  ['', 'Overview'],
  ['predict', 'Predict'],
  ['power', 'Power ranking'],
  ['teams', 'Teams'],
  ['bracket', 'Bracket'],
];
const href = (key: string) => (key ? `/analysis/${key}/` : '/analysis/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <Seo title={title} description={description} canonical={canonical} jsonLd={jsonLd} />
  </head>
  <body class="analysis min-h-screen antialiased">
    <SiteHeader active="analysis" />
    <div class="sticky top-[57px] z-20 border-b border-line bg-bg/90 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl flex-wrap gap-1 px-4 py-2">
        {NAV.map(([key, label]) => (
          <a
            href={href(key)}
            class:list={[
              'rounded-lg px-3 py-1.5 text-[13.5px] font-semibold',
              active === key
                ? 'bg-ball text-[#241c00]'
                : 'text-muted hover:bg-panel2 hover:text-ink',
            ]}
          >{label}</a>
        ))}
      </nav>
    </div>

    <div class="mx-auto max-w-5xl px-4 pb-20">
      <slot />
      <footer class="pt-10 pb-3 text-center text-xs text-muted">
        Real data to late June 2026 (Wikipedia, NBC Sports, SI, eloratings.net, FIFA ranking).<br />
        Forecasts are a transparent model (Elo + tournament form + squad + host advantage), not
        betting advice.
      </footer>
    </div>

    <style>
      .analysis {
        --bg: #16181d; --panel: #1e2129; --panel2: #242833; --line: #31353f;
        --text: #f4f2ec; --muted: #9a9ba4;
        --accent: #ffd23f; --accent2: #e8482b; --warn: #ffd23f; --danger: #e8482b;
        background: var(--bg);
        color: var(--text);
      }
    </style>
  </body>
</html>
