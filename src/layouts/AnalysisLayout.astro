---
// The analysis zone's shell — a dark analytics dashboard look, distinct from the
// light blog. Theme is scoped to this layout via CSS variables on .analysis so it
// never leaks into the rest of the site. Ported from the original prototype theme.
import '../styles/global.css';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  /** active nav key */
  active?: string;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, active = '', canonical, jsonLd } = Astro.props;

const NAV: [string, string][] = [
  ['', 'Overview'],
  ['predict', 'Predict'],
  ['power', 'Power ranking'],
  ['teams', 'Teams'],
  ['bracket', 'Bracket'],
];
// Overview ('') is the site home; the rest live under /analysis/.
const href = (key: string) => (key ? `/analysis/${key}/` : '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo title={title} description={description} canonical={canonical} jsonLd={jsonLd} />
  </head>
  <body class="analysis min-h-screen">
    <header
      class="sticky top-0 z-20 border-b border-[var(--line)] bg-[var(--bg)]/90 backdrop-blur"
    >
      <div class="mx-auto flex max-w-5xl flex-wrap items-center gap-3 px-4 py-3">
        <a
          href="/"
          class="font-display text-[17px] font-black tracking-tight whitespace-nowrap"
        >
          Kick<span class="text-[var(--accent2)]">about</span>
          <span class="ml-1 text-[13px] font-semibold text-[var(--muted)]">⚽ WC26</span>
        </a>
        <nav class="flex flex-1 flex-wrap gap-1">
          {NAV.map(([key, label]) => (
            <a
              href={href(key)}
              class:list={[
                'rounded-lg px-3 py-1.5 text-[13.5px] font-semibold',
                active === key
                  ? 'bg-[var(--accent)] text-[var(--bg)]'
                  : 'text-[var(--muted)] hover:bg-[var(--panel2)] hover:text-[var(--text)]',
              ]}
            >
              {label}
            </a>
          ))}
        </nav>
        <a href="/articles" class="text-[13px] text-[var(--muted)] hover:text-[var(--text)]"
          >← Blog</a
        >
      </div>
    </header>

    <div class="mx-auto max-w-5xl px-4 pb-20">
      <slot />
      <footer class="pt-10 pb-3 text-center text-xs text-[var(--muted)]">
        Real data to late June 2026 (Wikipedia, NBC Sports, SI, eloratings.net, FIFA ranking).<br />
        Forecasts are a transparent model (Elo + tournament form + squad + host advantage), not
        betting advice.
      </footer>
    </div>

    <style>
      .analysis {
        /* Kickabout brand — warm cream on charcoal, yellow + orange accents.
           Var names kept stable so all analysis components rebrand for free. */
        --bg: #16181d;
        --panel: #1e2128;
        --panel2: #262a32;
        --line: #2f3440;
        --text: #e9e1d2;
        --muted: #a59a85;
        --accent: #ffd23f;       /* signature yellow (ball) */
        --accent2: #e8482b;      /* orange flame */
        --warn: #ffd23f;
        --danger: #e8482b;
        background: var(--bg);
        color: var(--text);
      }
    </style>
  </body>
</html>
