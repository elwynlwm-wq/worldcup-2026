---
// Standard article layout: a centered, readable column using @tailwindcss/typography.
// Builds BlogPosting JSON-LD from the article's frontmatter. See docs/seo.md.
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { provider } from '../lib/provider';
import Flag from '../components/Flag.astro';
import { fixtureForStory, matchHref, KIND_META } from '../lib/stories';
import CommunityCTA from '../components/CommunityCTA.astro';
import MatchForecast from '../components/MatchForecast.astro';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;

const canonical = `/articles/${entry.id}/`;

// Derive kind + the two teams from tags (matches the stories hub vocabulary).
const tags = (entry.data.tags || []).map((t) => t.toLowerCase());
const kindKey = (['preview', 'recap', 'postmatch', 'teamanalytics', 'feature'] as const).find((k) => tags.includes(k)) ?? 'feature';
const kind = KIND_META[kindKey];
const teamIds = new Set(provider.getTeams().map((t) => t.id));
const matchTeams = tags.filter((t) => teamIds.has(t)).slice(0, 2).map((id) => provider.getTeam(id)!);
const [ta, tb] = matchTeams;
// Hero panel colour is FIXED by kind (design), not by team.
const heroColor = kind.hero;
const readMins = Math.max(1, Math.round((entry.body?.split(/\s+/).length ?? 200) / 200));
const dateMed = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });

// Link back to the match this story is about (evergreen — no open/closed wording).
const fixture = fixtureForStory(entry);
const matchUrl = fixture ? matchHref(fixture) : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(canonical, Astro.site).href },
};

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  canonical={canonical}
  publishDate={publishDate}
  updatedDate={updatedDate}
  author={author}
  jsonLd={jsonLd}
>
  <article class="kb-article mx-auto max-w-[680px] py-8">
    <a href="/articles" class="text-[13.5px] font-bold" style="color:#a59a85">← All stories</a>
    <div class="mt-[18px] flex items-center gap-2">
      <span class="font-display text-[11px] font-extrabold uppercase tracking-[1px]" style={`color:${kind.accent}`}>{kind.label}</span>
      <span class="text-[13px]" style="color:#b3a890">· {dateMed.format(publishDate)} · {readMins} min read</span>
    </div>
    <h1 class="font-display mt-3 mb-3 text-[38px] font-black leading-[1.03] tracking-[-1px] text-balance">{title}</h1>
    <p class="mb-[22px] text-[20px] font-medium leading-[1.45]" style="font-family:var(--font-serif);color:#3f3a30">{description}</p>

    {ta && tb && (
      <div class="relative mb-2 flex min-h-[150px] items-center justify-center gap-[22px] overflow-hidden rounded-[16px] px-[22px] py-[26px] text-white" style={`background:${heroColor}`}>
        <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(0,0,0,.4))"></div>
        <div class="absolute inset-0 opacity-40" style="background:url('/assets/pitch.svg') no-repeat center/cover"></div>
        <div class="relative text-center"><div class="mx-auto mb-[9px] w-fit"><Flag team={ta.id} w={74} class="shadow-[0_6px_16px_-6px_rgba(0,0,0,.6)] !ring-1 !ring-white/25" /></div><b class="font-display text-[15px]">{ta.name}</b></div>
        <div class="relative text-center"><div class="font-display text-[24px] font-black tracking-[.5px]" style="color:var(--color-gold)">VS</div></div>
        <div class="relative text-center"><div class="mx-auto mb-[9px] w-fit"><Flag team={tb.id} w={74} class="shadow-[0_6px_16px_-6px_rgba(0,0,0,.6)] !ring-1 !ring-white/25" /></div><b class="font-display text-[15px]">{tb.name}</b></div>
      </div>
    )}

    {matchUrl && (
      <a href={matchUrl} class="mt-[6px] mb-[4px] inline-block text-[14px] font-bold" style="color:var(--color-royal)">Get match analytics! →</a>
    )}

    {kindKey === 'preview' && ta && tb && <MatchForecast home={ta.id} away={tb.id} />}

    <div class="prose prose-lg mt-3.5 max-w-none prose-headings:font-display prose-headings:tracking-tight">
      <slot />
    </div>

    <div class="mt-3.5 border-t pt-4 text-[13px]" style="border-color:#e4dccd;color:#a59a85">
      {author}. Built on real squads, standings and our prediction model — not betting advice.
    </div>

    <CommunityCTA variant="story" />
  </article>

  <style>
    /* Light editorial reading tuned to the World Cup Analytics palette. Body in Newsreader
       serif for an editorial feel; links/headings in the brand. */
    .kb-article .prose {
      --tw-prose-body: var(--color-ink);
      --tw-prose-headings: var(--color-ink);
      --tw-prose-links: var(--color-royal);
      --tw-prose-bold: var(--color-ink);
      --tw-prose-quotes: var(--color-ink-2);
      --tw-prose-quote-borders: var(--color-gold);
      --tw-prose-bullets: var(--color-ink-3);
      --tw-prose-hr: var(--color-line);
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.7;
    }
    .kb-article .prose :is(h1, h2, h3, h4) { font-family: var(--font-display); }
  </style>
</BaseLayout>
