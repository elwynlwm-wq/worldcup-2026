---
// Standard article layout: a centered, readable column using @tailwindcss/typography.
// Builds BlogPosting JSON-LD from the article's frontmatter. See docs/seo.md.
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;

const canonical = `/articles/${entry.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(canonical, Astro.site).href },
};

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  canonical={canonical}
  publishDate={publishDate}
  updatedDate={updatedDate}
  author={author}
  jsonLd={jsonLd}
>
  <article class="kb-article mx-auto max-w-3xl px-4 py-10">
    <header class="mb-8">
      <h1 class="font-display text-4xl font-black tracking-tight text-balance">{title}</h1>
      <p class="mt-4 text-lg" style="color:var(--color-ink-dim)">{description}</p>
      <div class="mt-4 flex items-center gap-2 text-sm" style="color:var(--color-ink-muted)">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={publishDate.toISOString()}>{dateFmt.format(publishDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {dateFmt.format(updatedDate)}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose prose-lg prose-invert max-w-none prose-headings:font-display prose-headings:tracking-tight">
      <slot />
    </div>
  </article>

  <style>
    /* Dark long-form reading, tuned to the warm Kickabout palette — not a raw
       invert. Body sits at parchment (not pure white); links use the flame accent. */
    .kb-article {
      --tw-prose-invert-body: var(--color-ink);
      --tw-prose-invert-headings: #f3ecdd;
      --tw-prose-invert-links: var(--color-flame);
      --tw-prose-invert-bold: #f3ecdd;
      --tw-prose-invert-quotes: var(--color-ink-dim);
      --tw-prose-invert-quote-borders: var(--color-line);
      --tw-prose-invert-hr: var(--color-line);
      --tw-prose-invert-captions: var(--color-ink-muted);
      --tw-prose-invert-code: var(--color-ball);
      --tw-prose-invert-pre-bg: var(--color-panel);
      --tw-prose-invert-bullets: var(--color-ink-muted);
    }
  </style>
</BaseLayout>
