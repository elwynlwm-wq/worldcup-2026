---
// Standard article layout: a centered, readable column using @tailwindcss/typography.
// Builds BlogPosting JSON-LD from the article's frontmatter. See docs/seo.md.
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;

const canonical = `/articles/${entry.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(canonical, Astro.site).href },
};

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  canonical={canonical}
  publishDate={publishDate}
  updatedDate={updatedDate}
  author={author}
  jsonLd={jsonLd}
>
  <article class="kb-article mx-auto max-w-3xl py-10">
    <header class="mb-8">
      <h1 class="font-display text-[44px] font-black leading-[1.04] tracking-tight text-balance">{title}</h1>
      <p class="mt-4 text-[20px] leading-relaxed" style="font-family:var(--font-serif);color:var(--color-ink-2)">{description}</p>
      <div class="mt-4 flex items-center gap-2 text-sm" style="color:var(--color-ink-3)">
        <span class="font-semibold">{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={publishDate.toISOString()}>{dateFmt.format(publishDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {dateFmt.format(updatedDate)}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:tracking-tight">
      <slot />
    </div>
  </article>

  <style>
    /* Light editorial reading tuned to the Kickabout palette. Body in Newsreader
       serif for an editorial feel; links/headings in the brand. */
    .kb-article .prose {
      --tw-prose-body: var(--color-ink);
      --tw-prose-headings: var(--color-ink);
      --tw-prose-links: var(--color-royal);
      --tw-prose-bold: var(--color-ink);
      --tw-prose-quotes: var(--color-ink-2);
      --tw-prose-quote-borders: var(--color-gold);
      --tw-prose-bullets: var(--color-ink-3);
      --tw-prose-hr: var(--color-line);
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.7;
    }
    .kb-article .prose :is(h1, h2, h3, h4) { font-family: var(--font-display); }
  </style>
</BaseLayout>
