---
// The single site shell (light World Cup Analytics). Owns <html>, <head>, header/nav/footer.
// Ported from the design source (concepts/.../Kickabout.dc.html) — max-width 1080,
// sticky translucent header, logo + nav + search. One unified layout for the whole
// site (the old Base/Analysis split is retired now the theme is unified).
import '../styles/global.css';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
  /** active top-nav key for highlight */
  active?: string;
}

const { active = '', ...seoProps } = Astro.props;

const NAV: [string, string][] = [
  ['', 'Predict'],
  ['today', 'Today'],
  ['matches', 'Matches'],
  ['stories', 'Stories'],
  ['teams', 'Teams'],
  ['bracket', 'Bracket'],
  ['how-it-works', 'How it works'],
  ['about', 'About'],
];
const href = (key: string) =>
  key === '' ? '/' : key === 'stories' ? '/articles' : `/${key}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo {...seoProps} />
  </head>
  <body class="min-h-screen" style="display:flex;flex-direction:column">
    <header
      class="sticky top-0 z-40 border-b backdrop-blur"
      style="background:rgba(231,226,212,.86);border-color:var(--color-line-2)"
    >
      <div class="mx-auto flex max-w-[1080px] items-center gap-4 px-5 py-3">
        <a href="/" class="font-display flex flex-none items-center gap-2 text-[18px] font-black tracking-tight">
          <svg width="34" height="34" viewBox="0 0 40 40" aria-hidden="true">
            <circle cx="20" cy="20" r="14" fill="none" stroke="#c9c0a9" stroke-width="8" />
            <circle cx="20" cy="20" r="14" fill="none" stroke="var(--color-royal)" stroke-width="8" stroke-dasharray="48 88" transform="rotate(-90 20 20)" />
            <circle cx="20" cy="20" r="14" fill="none" stroke="var(--color-gold)" stroke-width="8" stroke-dasharray="22 88" stroke-dashoffset="-48" transform="rotate(-90 20 20)" />
            <circle cx="20" cy="20" r="9.6" fill="#fff" />
            <g stroke="var(--color-night)" stroke-width="1.6" stroke-linecap="round">
              <line x1="20" y1="15.5" x2="20" y2="10.9" /><line x1="24.28" y1="18.61" x2="28.6" y2="17.2" />
              <line x1="22.65" y1="23.64" x2="25.3" y2="27.3" /><line x1="17.35" y1="23.64" x2="14.7" y2="27.3" />
              <line x1="15.72" y1="18.61" x2="11.4" y2="17.2" />
            </g>
            <polygon points="20,15.5 24.28,18.61 22.65,23.64 17.35,23.64 15.72,18.61" fill="var(--color-night)" />
          </svg>
          World&nbsp;Cup&nbsp;<span style="color:var(--color-royal)">Analytics</span>
        </a>
        {/* desktop nav */}
        <nav class="hidden flex-1 flex-wrap gap-1 md:flex">
          {NAV.map(([key, label]) => (
            <a
              href={href(key)}
              class:list={['rounded-[10px] px-2.5 py-2 text-sm font-bold transition']}
              style={active === key ? 'color:#fff;background:var(--color-night)' : 'color:var(--color-ink-2)'}
            >
              {label}
            </a>
          ))}
        </nav>
        {/* desktop search */}
        <form action="/search" method="get" class="ml-auto hidden items-center gap-2 rounded-[11px] border px-3 py-2 md:flex"
          style="background:#fff;border-color:var(--color-line)">
          <span style="color:var(--color-ink-3)">⌕</span>
          <input name="q" placeholder="Search teams, players…" class="w-[110px] border-none bg-transparent text-sm outline-none" style="font-family:inherit;color:var(--color-ink)" />
        </form>
        {/* mobile actions: search toggle + hamburger */}
        <div class="ml-auto flex items-center gap-2 md:hidden">
          <button id="m-search-btn" aria-label="Search" class="flex h-9 w-9 items-center justify-center rounded-[10px] border" style="background:#fff;border-color:var(--color-line);color:var(--color-ink-2)">⌕</button>
          <button id="m-nav-btn" aria-label="Menu" class="flex h-9 w-9 items-center justify-center rounded-[10px] border text-[15px]" style="background:#fff;border-color:var(--color-line);color:var(--color-ink-2)">☰</button>
        </div>
      </div>

      {/* mobile search dropdown */}
      <div id="m-search" class="mx-auto hidden max-w-[1080px] px-5 pb-3 md:!hidden">
        <form action="/search" method="get" class="flex items-center gap-2 rounded-[11px] border px-3 py-2.5" style="background:#fff;border-color:var(--color-line)">
          <span style="color:var(--color-ink-3)">⌕</span>
          <input name="q" placeholder="Search teams, players…" class="w-full border-none bg-transparent text-sm outline-none" style="font-family:inherit;color:var(--color-ink)" />
        </form>
      </div>

      {/* mobile nav dropdown */}
      <nav id="m-nav" class="mx-auto hidden max-w-[1080px] flex-col gap-1 px-5 pb-3 md:!hidden">
        {NAV.map(([key, label]) => (
          <a
            href={href(key)}
            class="rounded-[10px] px-3 py-2.5 text-[15px] font-bold"
            style={active === key ? 'color:#fff;background:var(--color-night)' : 'color:var(--color-ink-2)'}
          >
            {label}
          </a>
        ))}
      </nav>
    </header>
    <script is:inline>
      (() => {
        const tgl = (el) => { if (el) el.style.display = el.style.display === 'flex' ? 'none' : 'flex'; };
        const nav = document.getElementById('m-nav');
        const search = document.getElementById('m-search');
        document.getElementById('m-nav-btn')?.addEventListener('click', () => { if (search) search.style.display = 'none'; tgl(nav); });
        document.getElementById('m-search-btn')?.addEventListener('click', () => { if (nav) nav.style.display = 'none'; tgl(search); const i = search?.querySelector('input'); if (search?.style.display === 'flex') setTimeout(() => i?.focus(), 30); });
      })();
    </script>

    <main class="mx-auto w-full max-w-[1080px] flex-1 px-5 pt-6 pb-[70px]">
      <slot />
    </main>

    <footer class="border-t" style="border-color:var(--color-line)">
      <div class="mx-auto max-w-[1080px] px-5 py-8 text-sm" style="color:var(--color-ink-3)">
        <p>
          World Cup Analytics — World Cup 2026 predictions, analysis &amp; stories. A free, fan-made site.
          Forecasts are a transparent model, not betting advice.
        </p>
        <p class="mt-2 flex flex-wrap gap-x-4 gap-y-1 font-bold">
          <a href="/about/" style="color:var(--color-ink-2)">About us</a>
          <a href="/how-it-works/" style="color:var(--color-ink-2)">How our forecasts work</a>
        </p>
      </div>
    </footer>
  </body>
</html>
