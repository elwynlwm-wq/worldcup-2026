---
// The site shell every page renders inside. Owns <html>, <head>, and the
// global chrome. Passes SEO props straight through to <Seo/>.
import '../styles/global.css';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
}

const seoProps = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo {...seoProps} />
  </head>
  <body
    class="min-h-screen antialiased"
    style="background:var(--color-bg);color:var(--color-ink)"
  >
    <header class="border-b" style="border-color:var(--color-line)">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/" class="font-display text-[17px] font-black tracking-tight">
          Kick<span style="color:var(--color-flame)">about</span>
          <span class="ml-1 text-[13px] font-semibold" style="color:var(--color-ink-dim)">⚽ WC26</span>
        </a>
        <div class="flex gap-6 text-sm font-semibold" style="color:var(--color-ink-dim)">
          <a href="/" class="hover:text-[var(--color-ink)]">Analysis</a>
          <a href="/articles" class="hover:text-[var(--color-ink)]">Articles</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t" style="border-color:var(--color-line)">
      <div class="mx-auto max-w-5xl px-4 py-8 text-sm" style="color:var(--color-ink-muted)">
        <p>Kickabout — World Cup 2026 predictions, analysis &amp; stories. A free, fan-made site.</p>
      </div>
    </footer>
  </body>
</html>
