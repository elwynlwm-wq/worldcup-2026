---
// The single site shell (light World Cup Analytics). Owns <html>, <head>, header/nav/footer.
// Ported from the design source (concepts/.../Kickabout.dc.html) — max-width 1080,
// sticky translucent header, logo + nav + search. One unified layout for the whole
// site (the old Base/Analysis split is retired now the theme is unified).
import '../styles/global.css';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
  /** active top-nav key for highlight */
  active?: string;
}

const { active = '', ...seoProps } = Astro.props;

const NAV: [string, string][] = [
  ['', 'Predict'],
  ['matches', 'Matches'],
  ['stories', 'Stories'],
  ['teams', 'Teams'],
  ['bracket', 'Bracket'],
];
const href = (key: string) =>
  key === '' ? '/' : key === 'stories' ? '/articles' : `/${key}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (() => {
        try {
          const pref = localStorage.getItem('wca-theme');
          const night = new Date().getHours() >= 19 || new Date().getHours() < 7;
          if (pref === 'dark' || (!pref && night)) document.documentElement.classList.add('dark');
        } catch {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Seo {...seoProps} />
  </head>
  <body class="min-h-screen" style="display:flex;flex-direction:column">
    <header
      class="sticky top-0 z-40 border-b backdrop-blur"
      style="background:var(--header-glass);border-color:var(--color-line-2)"
    >
      <div class="mx-auto flex max-w-[1080px] items-center gap-3 px-5 py-3">
        <a href="/" class="font-display flex flex-none items-center gap-2 text-[18px] font-black tracking-tight">
          <svg width="34" height="34" viewBox="0 0 40 40" aria-hidden="true">
            <circle cx="20" cy="20" r="14" fill="none" stroke="#c9c0a9" stroke-width="8" />
            <circle cx="20" cy="20" r="14" fill="none" stroke="var(--color-royal)" stroke-width="8" stroke-dasharray="48 88" transform="rotate(-90 20 20)" />
            <circle cx="20" cy="20" r="14" fill="none" stroke="var(--color-gold)" stroke-width="8" stroke-dasharray="22 88" stroke-dashoffset="-48" transform="rotate(-90 20 20)" />
            <circle cx="20" cy="20" r="9.6" fill="#fff" />
            <g stroke="var(--color-night)" stroke-width="1.6" stroke-linecap="round">
              <line x1="20" y1="15.5" x2="20" y2="10.9" /><line x1="24.28" y1="18.61" x2="28.6" y2="17.2" />
              <line x1="22.65" y1="23.64" x2="25.3" y2="27.3" /><line x1="17.35" y1="23.64" x2="14.7" y2="27.3" />
              <line x1="15.72" y1="18.61" x2="11.4" y2="17.2" />
            </g>
            <polygon points="20,15.5 24.28,18.61 22.65,23.64 17.35,23.64 15.72,18.61" fill="var(--color-night)" />
          </svg>
          World&nbsp;Cup&nbsp;<span style="color:var(--color-royal)">Analytics</span>
        </a>
        {/* desktop nav */}
        <nav class="hidden flex-1 flex-nowrap gap-0.5 overflow-x-auto md:flex" style="scrollbar-width:none">
          {NAV.map(([key, label]) => (
            <a
              href={href(key)}
              class:list={['rounded-[10px] px-2 py-2 text-sm font-bold whitespace-nowrap transition']}
              style={active === key ? 'color:#fff;background:var(--color-night)' : 'color:var(--color-ink-2)'}
            >
              {label}
            </a>
          ))}
        </nav>
        {/* desktop search */}
        <form action="/search" method="get" class="ml-auto hidden items-center gap-2 rounded-[11px] border px-3 py-2 lg:flex"
          style="background:var(--color-surface);border-color:var(--color-line)">
          <span style="color:var(--color-ink-3)">⌕</span>
          <input name="q" placeholder="Search…" class="w-[90px] border-none bg-transparent text-sm outline-none" style="font-family:inherit;color:var(--color-ink)" />
        </form>
        {/* mobile actions: theme + search toggle + hamburger (below md) */}
        <button id="theme-btn" aria-label="Toggle floodlight mode" title="Floodlight mode"
          class="ml-auto flex h-9 w-9 flex-none items-center justify-center rounded-[10px] border text-[15px] lg:ml-3"
          style="background:var(--color-surface);border-color:var(--color-line);color:var(--color-ink-2)">☾</button>
        <div class="flex items-center gap-2 lg:hidden">
          <button id="m-search-btn" aria-label="Search" class="flex h-9 w-9 items-center justify-center rounded-[10px] border" style="background:var(--color-surface);border-color:var(--color-line);color:var(--color-ink-2)">⌕</button>
          <button id="m-menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="m-menu" class="flex h-9 w-9 items-center justify-center rounded-[10px] border md:hidden" style="background:var(--color-surface);border-color:var(--color-line);color:var(--color-ink-2)">
            <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="2.5" y1="5" x2="15.5" y2="5" /><line x1="2.5" y1="9" x2="15.5" y2="9" /><line x1="2.5" y1="13" x2="15.5" y2="13" />
            </svg>
          </button>
        </div>
      </div>

      {/* mobile search dropdown */}
      <div id="m-search" class="mx-auto hidden max-w-[1080px] px-5 pb-3 lg:!hidden">
        <form action="/search" method="get" class="flex items-center gap-2 rounded-[11px] border px-3 py-2.5" style="background:var(--color-surface);border-color:var(--color-line)">
          <span style="color:var(--color-ink-3)">⌕</span>
          <input name="q" placeholder="Search teams, players…" class="w-full border-none bg-transparent text-sm outline-none" style="font-family:inherit;color:var(--color-ink)" />
        </form>
      </div>

      {/* phone nav — hamburger drawer: hidden until toggled, full vertical list */}
      <nav id="m-menu" class="mx-auto hidden max-w-[1080px] px-5 pb-3 md:!hidden" aria-label="Primary">
        <div class="flex flex-col gap-1 rounded-[13px] border p-1.5" style="background:#fff;border-color:var(--color-line)">
          {NAV.map(([key, label]) => (
            <a
              href={href(key)}
              aria-current={active === key ? 'page' : undefined}
              class="rounded-[10px] px-3.5 py-2.5 text-[15px] font-bold"
              style={active === key ? 'color:#fff;background:var(--color-night)' : 'color:var(--color-ink-2)'}
            >
              {label}
            </a>
          ))}
        </div>
      </nav>
    </header>
    <script is:inline>
      (() => {
        const btn = document.getElementById('theme-btn');
        const sync = () => { if (btn) btn.textContent = document.documentElement.classList.contains('dark') ? '☀' : '☾'; };
        sync();
        btn?.addEventListener('click', () => {
          const el = document.documentElement;
          el.classList.toggle('dark');
          try { localStorage.setItem('wca-theme', el.classList.contains('dark') ? 'dark' : 'light'); } catch {}
          sync();
        });
        const search = document.getElementById('m-search');
        const menu = document.getElementById('m-menu');
        const menuBtn = document.getElementById('m-menu-btn');
        const setMenu = (open) => {
          if (!menu) return;
          menu.style.display = open ? 'block' : 'none';
          menuBtn?.setAttribute('aria-expanded', open ? 'true' : 'false');
        };
        const setSearch = (open) => {
          if (!search) return;
          search.style.display = open ? 'block' : 'none';
          if (open) setTimeout(() => search.querySelector('input')?.focus(), 30);
        };
        document.getElementById('m-search-btn')?.addEventListener('click', () => {
          const open = search?.style.display !== 'block';
          setSearch(open);
          if (open) setMenu(false); // only one panel at a time
        });
        menuBtn?.addEventListener('click', () => {
          const open = menu?.style.display !== 'block';
          setMenu(open);
          if (open) setSearch(false);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') { setMenu(false); setSearch(false); }
        });
      })();
    </script>

    <main class="mx-auto w-full max-w-[1080px] flex-1 px-5 pt-6 pb-[70px]">
      <slot />
    </main>

    <div aria-hidden="true" style="background:var(--color-pitch);overflow:hidden">
      <svg viewBox="0 0 1080 52" preserveAspectRatio="xMidYMid slice" class="mx-auto block h-[52px] w-full max-w-[1400px]" style="opacity:.22">
        <g fill="none" stroke="#fff" stroke-width="2">
          <line x1="0" y1="4" x2="1080" y2="4" />
          <line x1="540" y1="4" x2="540" y2="52" />
          <circle cx="540" cy="52" r="34" />
          <rect x="150" y="4" width="120" height="34" />
          <rect x="810" y="4" width="120" height="34" />
        </g>
      </svg>
    </div>
    <footer class="border-t" style="border-color:var(--color-line)">
      <div class="mx-auto max-w-[1080px] px-5 py-8 text-sm" style="color:var(--color-ink-3)">
        <p>
          World Cup Analytics — World Cup 2026 predictions, analysis &amp; stories. A free, fan-made site.
          Forecasts are a transparent model, not betting advice.
        </p>
        <p class="mt-2 flex flex-wrap gap-x-4 gap-y-1 font-bold">
          <a href="/today/" style="color:var(--color-ink-2)">Today's games</a>
          <a href="/record/" style="color:var(--color-ink-2)">Model record</a>
          <a href="/how-it-works/" style="color:var(--color-ink-2)">How our forecasts work</a>
          <a href="/about/" style="color:var(--color-ink-2)">About us</a>
        </p>
      </div>
    </footer>
  </body>
</html>
