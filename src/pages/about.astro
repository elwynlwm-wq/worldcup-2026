---
// About page — the humans (well, pen names) behind World Cup Analytics. Exists for
// readers first, and for E-E-A-T / ads-verification second: who we are, why
// we do this, how to reach us, and the not-a-bookmaker line in plain sight.
import BaseLayout from '../layouts/BaseLayout.astro';
import FounderAvatar from '../components/FounderAvatar.astro';
import WhiteboardDoodle from '../components/WhiteboardDoodle.astro';
import Flag from '../components/Flag.astro';

const DESK = [
  {
    id: 'weijun',
    name: 'Tan Wei Jun',
    role: 'Editor',
    bio: 'Decides what gets covered and writes most of the pre-match calls. Has backed a doomed dark horse at every World Cup since 2006 and sees no reason to stop.',
    sig: 'Chipped the market on Japan when everyone else had Brazil in cruise control.',
    flaw: 'Dark horses. Always the dark horses.',
    favTeam: { id: 'japan', name: 'Japan', href: '/articles/brazil-japan-postmatch/' },
    favPlayer: { name: 'Ayase Ueda', href: '/articles/japan-analytics/' },
  },
  {
    id: 'aisyah',
    name: 'Aisyah Rahim',
    role: 'The numbers',
    bio: 'Built the forecast model and keeps the data pipeline honest. Believes a spreadsheet can love football too, and that xG is a description, not an excuse.',
    sig: 'The 28% draw term — her favourite number on the whole site.',
    flaw: "Refuses to model penalty shootouts. \"Coin flips don't need a spreadsheet.\"",
    favTeam: { id: 'spain', name: 'Spain', href: '/articles/spain-analytics/' },
    favPlayer: { name: 'Rodri', href: '/articles/spain-austria-preview/' },
  },
  {
    id: 'hafiz',
    name: 'Hafiz Ismail',
    role: 'Teams & players',
    bio: 'Writes the team analytics and player deep dives. Watches the full 90 of games nobody else will, then tells you which full-back quietly won it.',
    sig: 'Flagged the quiet left-back three games before the pundits did.',
    flaw: 'Falls in love with a deep-lying playmaker every single tournament.',
    favTeam: { id: 'morocco', name: 'Morocco', href: '/articles/morocco-analytics/' },
    favPlayer: { name: 'Achraf Hakimi', href: '/articles/netherlands-morocco-preview/' },
  },
] as const;

const FAQ = [
  {
    q: 'Do you take bets or sell tips?',
    a: "No. World Cup Analytics is not a bookmaker, has no affiliate deals with bookmakers, and sells nothing. Our forecasts are probabilities from a published model, not betting advice.",
  },
  {
    q: 'How do the forecasts actually work?',
    a: "Each team gets an Elo rating adjusted for tournament form, squad firepower and host advantage. The gap between two teams' ratings becomes win, draw and loss probabilities. The full formula — with the exact weightings — is on our how-it-works page, where you can also run it yourself.",
  },
  {
    q: 'Where does your data come from?',
    a: 'Results, expected goals, lineups, injuries and odds live in our own data warehouse, refreshed hourly during the tournament. We never invent scorelines, injuries or quotes, and derived estimates are labelled as ours.',
  },
  {
    q: 'Why do you write under pen names?',
    a: "We're a small group of friends doing this out of love for the World Cup, and we'd rather the football did the talking. Judge us on the method and the record: every forecast we publish stays up, right or wrong.",
  },
  {
    q: 'The model got a match badly wrong. What gives?',
    a: "A 70% favourite loses three times in ten — probabilities aren't promises. What we owe you is a model that's honest and consistent over the whole tournament, not one that's right every night.",
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQ.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About World Cup Analytics',
  mainEntity: {
    '@type': 'Organization',
    name: 'World Cup Analytics',
    url: 'https://worldcup-site-ten.vercel.app',
    description:
      'A free, fan-made World Cup 2026 predictions and analysis site. Transparent model forecasts, not betting advice.',
  },
  },
];
---

<BaseLayout
  title="About us — World Cup Analytics | World Cup 2026"
  description="Who's behind World Cup Analytics, why we built a free World Cup 2026 predictions site, and the rules we hold ourselves to. Fan-made, data-first, not a bookmaker."
  canonical="/about/"
  jsonLd={jsonLd}
>
  <div class="kb-route">
    <h1 class="font-display text-[34px] font-black tracking-[-1px]">Built out of love for the World Cup</h1>
    <p class="mt-1 max-w-[820px] text-[15.5px]" style="color:#6f6655">
      World Cup Analytics is a free, fan-made site. Nobody pays us, nothing is sponsored, and we don't take bets.
      We do this because the World Cup is the best thing in sport and we wanted a place that treats it that way.
    </p>

    <section class="mt-6">
      <h2 class="font-display text-[22px] font-black tracking-[-0.5px]">The story</h2>
      <div class="mt-2 space-y-3 text-[15px] leading-[1.65]" style="color:var(--color-ink-2)">
        <p>
          This started as a group chat argument. The first 48-team World Cup was coming, one of us had a
          rating model, one of us had opinions about Morocco's midfield, and none of us — despite living seven
          time zones from the stadiums — could find a site that showed an honest forecast for every fixture without trying to sell a betting slip on the way.
          So we built one.
        </p>
        <p>
          Every match on World Cup Analytics gets a model call — win, draw and loss probabilities from a formula we
          publish in full — shown next to what the betting market thinks, so you can see where we agree and
          where we're being brave. Around that we write previews, post-match analytics and a data profile
          of all 48 teams.
        </p>
        <p>
          The rule we hold ourselves to: facts come from our data warehouse, colour comes from watching the
          games. We never invent scorelines, injuries or quotes, and when a number is our own estimate
          (like a rating tier) we say so rather than passing it off as fact.
        </p>
      </div>
    </section>

    <div class="mt-8 grid gap-5 pt-2 sm:grid-cols-3">
      <WhiteboardDoodle variant="tactics" tilt="-1.2deg" caption="Night one: the group-chat tactics board" />
      <WhiteboardDoodle variant="clock" tilt="0.9deg" caption="Every kickoff is 3am here" />
      <WhiteboardDoodle variant="bracket" tilt="-0.7deg" caption="The wall chart nobody agrees on" />
    </div>

    <section class="mt-7">
      <h2 class="font-display text-[22px] font-black tracking-[-0.5px]">The team behind the scenes</h2>
      <p class="mt-1 text-[14px]" style="color:#6f6655">
        We're a small crew of friends in Southeast Asia, which for this World Cup means alarms at 3am
        and predictions filed before sunrise. We write under pen names — we'd rather the football did the talking.
      </p>
      <div class="mt-3 grid gap-3 sm:grid-cols-3">
        {DESK.map((p) => (
          <div class="rounded-[16px] border p-4 text-center" style="background:#fff;border-color:#e9e1d2">
            <div class="mx-auto w-[104px]"><FounderAvatar who={p.id} size={104} /></div>
            <div class="font-display mt-2 text-[17px] font-black">{p.name}</div>
            <div class="text-[12px] font-bold uppercase tracking-[0.4px]" style="color:var(--color-royal)">{p.role}</div>
            <p class="mt-2 text-left text-[13.5px] leading-[1.55]" style="color:var(--color-ink-2)">{p.bio}</p>
            <div class="mt-3 rounded-[10px] px-3 py-2 text-left" style="background:var(--color-surface-2)">
              <div class="text-[10.5px] font-bold uppercase tracking-[0.5px]" style="color:var(--color-pitch)">Signature call</div>
              <p class="mt-0.5 text-[12.5px] leading-[1.5]" style="color:var(--color-ink-2)">{p.sig}</p>
            </div>
            <div class="mt-2 rounded-[10px] px-3 py-2 text-left" style="background:var(--color-surface-2)">
              <div class="text-[10.5px] font-bold uppercase tracking-[0.5px]" style="color:var(--color-clay)">Known weakness</div>
              <p class="mt-0.5 text-[12.5px] leading-[1.5]" style="color:var(--color-ink-2)">{p.flaw}</p>
            </div>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <a href={p.favTeam.href} class="rounded-[10px] border px-2.5 py-2 text-left transition hover:border-[var(--color-royal)]" style="background:#fff;border-color:var(--color-line)">
                <div class="text-[10.5px] font-bold uppercase tracking-[0.5px]" style="color:var(--color-royal)">Favourite team</div>
                <div class="mt-1 flex items-center gap-1.5 text-[12.5px] font-bold" style="color:var(--color-ink)">
                  <Flag team={p.favTeam.id} w={18} /> {p.favTeam.name}
                </div>
              </a>
              <a href={p.favPlayer.href} class="rounded-[10px] border px-2.5 py-2 text-left transition hover:border-[var(--color-royal)]" style="background:#fff;border-color:var(--color-line)">
                <div class="text-[10.5px] font-bold uppercase tracking-[0.5px]" style="color:var(--color-royal)">Favourite player</div>
                <div class="mt-1 text-[12.5px] font-bold" style="color:var(--color-ink)">{p.favPlayer.name}</div>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-7">
      <h2 class="font-display text-[22px] font-black tracking-[-0.5px]">How we make our calls</h2>
      <p class="mt-2 text-[15px] leading-[1.65]" style="color:var(--color-ink-2)">
        The forecast is a transparent rating model: an Elo base adjusted for tournament form, squad
        firepower and host advantage, turned into win, draw and loss probabilities. No black box, no vibes
        dressed up as maths. The full formula, including the exact weightings, is on our
        <a href="/how-it-works/" class="font-bold" style="color:var(--color-royal)">how it works</a> page —
        where you can pick any two teams and run the model yourself.
      </p>
    </section>

    <section class="mt-7">
      <h2 class="font-display text-[22px] font-black tracking-[-0.5px]">Fair questions</h2>
      <div class="mt-3 overflow-hidden rounded-[16px] border" style="background:#fff;border-color:#e9e1d2">
        {FAQ.map((f) => (
          <details class="faq-item border-b" style="border-color:#f1ebdf">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3.5 text-[15px] font-bold select-none">
              {f.q}
              <span class="faq-chev flex-none text-[13px] transition-transform" style="color:var(--color-royal)">▾</span>
            </summary>
            <p class="px-4 pb-4 text-[14px] leading-[1.6]" style="color:var(--color-ink-2)">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mt-7 rounded-[16px] border p-5" style="background:#fff;border-color:#e9e1d2">
      <h2 class="font-display text-[18px] font-black tracking-[-0.5px]">The small print that isn't small</h2>
      <p class="mt-2 text-[14.5px] leading-[1.6]" style="color:var(--color-ink-2)">
        World Cup Analytics is not a bookmaker and is not affiliated with one. We don't take bets, sell tips or earn
        commission from gambling operators. Our forecasts are probabilities, not promises, and they are not
        betting advice. If you gamble, please do it responsibly.
      </p>
      <p class="mt-3 text-[14.5px]" style="color:var(--color-ink-2)">
        Spotted a mistake? We correct errors quickly and visibly — the fastest way to flag one is to
        vote against us on the fixture and feel smug later.
      </p>
    </section>
  </div>

  <style>
    .faq-item:last-child { border-bottom: none; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item[open] .faq-chev { transform: rotate(180deg); }
  </style>
</BaseLayout>
