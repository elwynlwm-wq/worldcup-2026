---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import { provider } from '../../../lib/provider';
import { getPlayerTiers } from '../../../lib/warehouse';
import TierBadge from '../../../components/analysis/TierBadge.astro';
import Avatar from '../../../components/analysis/Avatar.astro';

export function getStaticPaths() {
  return provider.getTeams().map((t) => ({ params: { id: t.id }, props: { teamId: t.id } }));
}

const { teamId } = Astro.props;
const t = provider.getTeam(teamId)!;
const squad = provider.getSquad(teamId);

// Warehouse tiers per player (build-time). Map by id for cheap lookup.
const tiersById = new Map(squad.map((p) => [p.id, getPlayerTiers(p.id)]));

// Squad-strength summary: count Elite/Established players (newbie-friendly).
const eliteCount = squad.filter((p) => tiersById.get(p.id)?.playerTier === 'Elite').length;
const establishedCount = squad.filter(
  (p) => tiersById.get(p.id)?.playerTier === 'Established',
).length;

const byPos = (pos: string) => squad.filter((p) => p.pos === pos);
const POS: [string, string][] = [
  ['GK', 'Goalkeepers'],
  ['DF', 'Defenders'],
  ['MF', 'Midfielders'],
  ['FW', 'Forwards'],
];

const factors: [string, string | number][] = [
  ['Elo rating', t.elo],
  ['FIFA ranking', '#' + t.fifaRank],
  ['Tournament form', (t.formAdj > 0 ? '+' : '') + t.formAdj],
  ['Squad attack', (t.squadAdj > 0 ? '+' : '') + t.squadAdj],
  ['Home advantage', (t.hostAdj > 0 ? '+' : '') + t.hostAdj],
  ['Adjusted rating', t.adjRating],
  ['Strength (0–100)', t.strength],
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsTeam',
  name: t.name,
  sport: 'Football',
  coach: t.coachName ? { '@type': 'Person', name: t.coachName } : undefined,
};
---

<AnalysisLayout
  title={`${t.name} — World Cup 2026 Analysis`}
  description={`${t.name} at the 2026 World Cup: full squad, coach ${t.coachName ?? ''}, group ${t.groupLetter} standing, and the rating factors behind their forecasts.`}
  active="teams"
  canonical={`/analysis/teams/${t.id}/`}
  jsonLd={jsonLd}
>
  <a href="/analysis/teams/" class="text-[13px] text-[var(--muted)] hover:text-[var(--accent)]"
    >← All teams</a
  >
  <h1 class="mt-2 mb-1 text-2xl font-bold">{t.name}</h1>
  <p class="text-[13.5px] text-[var(--muted)]">
    {t.confederation} · Group {t.groupLetter} · {t.coachName ?? 'Coach TBC'}
  </p>

  <div class="mt-4 flex flex-wrap gap-2">
    <a
      href={`/analysis/predict/?a=${t.id}&b=brazil`}
      class="rounded-lg bg-[var(--accent)] px-3 py-1.5 text-[13px] font-semibold text-[#04130b]"
    >
      Predict a match for {t.name} →
    </a>
  </div>

  <h2 class="mt-6 mb-2 text-lg font-bold">Rating factors</h2>
  <table class="w-full max-w-md border-collapse text-[13.5px]">
    <tbody>
      {factors.map(([label, val]) => (
        <tr>
          <td class="border-b border-[var(--line)] px-2.5 py-2 text-[var(--muted)]">{label}</td>
          <td class="border-b border-[var(--line)] px-2.5 py-2 text-right font-bold tabular-nums">
            {val}
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2 class="mt-6 mb-1 text-lg font-bold">Squad</h2>
  <p class="mb-3 text-[13.5px] text-[var(--muted)]">
    Strength of this squad: <b class="text-[var(--accent)]">{eliteCount} elite</b> ·
    {establishedCount} established players. Tier badges blend each player's club, caps and goals —
    our own coarse signal, not an official rating.
  </p>
  {POS.map(([pos, label]) => (
    <div class="mb-4">
      <h3 class="mb-1 text-[12px] uppercase tracking-wide text-[var(--muted)]">{label}</h3>
      <div class="grid gap-1.5 sm:grid-cols-2">
        {byPos(pos).map((p) => {
          const tiers = tiersById.get(p.id);
          return (
            <div class="flex items-center justify-between gap-2 rounded-lg border border-[var(--line)] bg-[var(--panel)] px-3 py-1.5">
              <span class="flex items-center gap-2">
                <Avatar name={p.name} position={p.pos} photo={tiers?.photo ?? null} size={30} />
                <span class="font-medium">{p.name}</span>
                <TierBadge label={tiers?.playerTier ?? null} kind="player" />
              </span>
              <span class="flex items-center gap-2 text-[11px] text-[var(--muted)]">
                <span>{p.age}y · {p.club} · {p.goals}g</span>
                <TierBadge label={tiers?.clubTier ?? null} kind="club" />
              </span>
            </div>
          );
        })}
      </div>
    </div>
  ))}
</AnalysisLayout>
