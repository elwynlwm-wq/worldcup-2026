---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
---

<BaseLayout
  title="Stories — World Cup 2026"
  description="All our World Cup 2026 articles: predictions, analysis, match previews and reviews, written for every kind of fan."
  active="articles"
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-4xl font-extrabold tracking-tight">Stories</h1>
    <ul class="mt-8 divide-y divide-[var(--line)]">
      {articles.map((a) => (
        <li class="py-6">
          <a href={`/articles/${a.id}/`} class="group block">
            <h2 class="font-display text-2xl font-bold tracking-tight text-ink group-hover:text-ball">
              {a.data.title}
            </h2>
            <p class="mt-2 text-muted">{a.data.description}</p>
            <time
              datetime={a.data.publishDate.toISOString()}
              class="mt-2 block text-sm text-muted"
            >{dateFmt.format(a.data.publishDate)}</time>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
