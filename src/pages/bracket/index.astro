---
// Bracket & groups — knockout columns (from AF fixtures) + real group tables.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { getAfFixtures, lifecycle, liveLabel } from '../../lib/warehouse';
import standingsData from '../../../data-pipeline/warehouse/export/standings.json';
import Flag from '../../components/Flag.astro';

const getTeam = (id: string) => provider.getTeam(id);
const fixtures = getAfFixtures();

// The knockout tree: fixed slot count per round (16→8→4→2→1). Each round renders
// ALL its slots — a confirmed tie or a TBD placeholder — so the tree stays whole
// and the connectors line up before the draw resolves.
const ROUNDS: { stage: string; title: string; slots: number }[] = [
  { stage: 'r32', title: 'Round of 32', slots: 16 },
  { stage: 'r16', title: 'Round of 16', slots: 8 },
  { stage: 'qf', title: 'Quarter-finals', slots: 4 },
  { stage: 'sf', title: 'Semi-finals', slots: 2 },
  { stage: 'final', title: 'Final', slots: 1 },
];
const byStage = (s: string) => fixtures.filter((m) => m.stage === s && getTeam(m.homeTeamId) && getTeam(m.awayTeamId));
// pad a round's confirmed ties up to its fixed slot count with nulls (TBD)
const slotsFor = (stage: string, n: number) => {
  const ties = byStage(stage);
  return Array.from({ length: n }, (_, i) => ties[i] ?? null);
};
const dateLabel = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '');
const matchHref = (m: any) => `/matches/${m.homeTeamId}-vs-${m.awayTeamId}-${m.stage}`;

const standings = standingsData as Record<string, Array<{ rank: number; teamId: string; played: number; points: number; goalsFor: number; goalsAgainst: number; form: string }>>;
// Only the 12 real groups ("Group A".."Group L") — drop any stray aggregate key.
const groupNames = Object.keys(standings).filter((g) => /^Group [A-L]$/.test(g)).sort();
---

<BaseLayout
  title="Bracket & Groups — World Cup 2026 | Kickabout"
  description="The 2026 World Cup knockout bracket and all 12 group tables — the road to the final on 19 July."
  active="bracket"
  canonical="/bracket/"
>
  <div class="kb-route">
    <h1 class="font-display text-[34px] font-black tracking-tight">Bracket &amp; groups</h1>
    <p class="mt-0.5 mb-4 max-w-[620px] text-[15px]" style="color:var(--color-ink-2)">
      The knockout path and the group tables. Confirmed ties fill in as rounds resolve.
    </p>

    <h2 class="font-display mb-1 text-[20px] font-extrabold">The road to the final</h2>
    <p class="mb-2 text-[13px]" style="color:var(--color-ink-3)">Scroll right to follow the path to the final on 19 July.</p>
    <div class="kb-bracket">
      {ROUNDS.map(({ stage, title, slots }) => {
        const confirmed = byStage(stage).length;
        return (
          <div class="kb-round">
            <div class="kb-round-head flex items-baseline gap-[7px]">
              <span class="font-display text-[11.5px] font-extrabold uppercase tracking-[.5px]">{title}</span>
              <span class="text-[10.5px] font-semibold" style="color:#a59a85">{confirmed ? `${confirmed} ties` : `${slots} ties`}</span>
            </div>
            <div class="kb-ties">
              {slotsFor(stage, slots).map((m) => {
                if (!m) {
                  return (
                    <div class="kb-tie">
                      <div class="kb-tie-card rounded-[11px] border border-dashed px-[11px] py-[9px]" style="border-color:#e4dccd;background:#faf6ee">
                        <div class="mb-1.5 h-[11px] text-[9px] font-extrabold uppercase tracking-[.4px]" style="color:#cabfa9"></div>
                        <div class="flex items-center gap-[7px]"><span class="h-[15px] w-[22px] flex-none rounded-[3px]" style="background:#ece4d4"></span><span class="flex-1 text-[13px] font-bold" style="color:#b3a890">TBD</span></div>
                        <div class="my-1.5 h-px" style="background:#f1ebdf"></div>
                        <div class="flex items-center gap-[7px]"><span class="h-[15px] w-[22px] flex-none rounded-[3px]" style="background:#ece4d4"></span><span class="flex-1 text-[13px] font-bold" style="color:#b3a890">TBD</span></div>
                      </div>
                    </div>
                  );
                }
                const h = getTeam(m.homeTeamId)!, a = getTeam(m.awayTeamId)!;
                const isLive = lifecycle(m.status) === 'live';
                return (
                  <div class="kb-tie">
                    <a href={matchHref(m)} class="kb-tie-card kb-card-hover rounded-[11px] border px-[11px] py-[9px]" style={`background:#fff;border-color:${isLive ? 'var(--color-clay)' : '#e9e1d2'}`}>
                      {isLive ? (
                        <div class="mb-1.5 h-[11px] text-[9px] font-extrabold uppercase tracking-[.4px]" style="color:var(--color-clay)">● {liveLabel(m.status, m.elapsed)}</div>
                      ) : (
                        <div class="mb-1.5 h-[11px] text-[9px] font-extrabold uppercase tracking-[.4px]" style="color:#b3a890">{dateLabel(m.date)}</div>
                      )}
                      <div class="flex items-center gap-[7px]"><Flag team={h.id} w={22} /><b class="flex-1 text-[13px]">{h.shortCode}</b><span class="font-display text-[12px] font-extrabold">{m.homeScore ?? ''}</span></div>
                      <div class="my-1.5 h-px" style="background:#f1ebdf"></div>
                      <div class="flex items-center gap-[7px]"><Flag team={a.id} w={22} /><b class="flex-1 text-[13px]">{a.shortCode}</b><span class="font-display text-[12px] font-extrabold">{m.awayScore ?? ''}</span></div>
                    </a>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <div class="mb-3 mt-7 flex flex-wrap items-baseline justify-between gap-2">
      <h2 class="font-display text-[20px] font-extrabold">Groups</h2>
      <div class="flex gap-3.5 text-[12px] font-bold" style="color:#6f6655">
        <span class="inline-flex items-center gap-[5px]"><span class="h-[9px] w-[9px] rounded-full" style="background:#138a5e"></span>Through</span>
        <span class="inline-flex items-center gap-[5px]"><span class="h-[9px] w-[9px] rounded-full" style="background:#f3b50a"></span>In contention</span>
        <span class="inline-flex items-center gap-[5px]"><span class="h-[9px] w-[9px] rounded-full" style="background:#d8cfbf"></span>Out</span>
      </div>
    </div>
    <div class="grid gap-3.5" style="grid-template-columns:repeat(auto-fill,minmax(310px,1fr))">
      {groupNames.map((gname) => (
        <div class="overflow-hidden rounded-[15px] border" style="background:#fff;border-color:#e9e1d2">
          <div class="flex items-center justify-between px-[15px] pb-[9px] pt-3">
            <span class="font-display text-[15px] font-extrabold">{gname}</span>
            <span class="text-[10px] font-bold tracking-[.5px]" style="color:#b3a890">P GD PTS</span>
          </div>
          {standings[gname].map((row) => {
            const t = getTeam(row.teamId);
            const gd = row.goalsFor - row.goalsAgainst;
            // top 2 through (green), 3rd in contention (gold), 4th out (clay)
            const accent = row.rank <= 2 ? '#138a5e' : row.rank === 3 ? '#f3b50a' : '#d8cfbf';
            return (
              <a href={t ? `/teams/${t.id}/` : '#'} class="flex items-center gap-[9px] border-t px-[15px] py-[9px]" style="border-color:#f4eee1">
                <span class="h-[6px] w-[6px] flex-none rounded-full" style={`background:${accent}`}></span>
                <span class="font-display w-[10px] text-[12px] font-extrabold" style="color:#a59a85">{row.rank}</span>
                <Flag team={row.teamId} w={26} />
                <b class="flex-1 truncate text-[13.5px]">{t?.name ?? row.teamId}</b>
                <span class="w-4 text-center text-[12.5px] tabular-nums" style="color:#b3a890">{row.played}</span>
                <span class="w-[30px] text-center text-[12.5px] tabular-nums" style="color:#6f6655">{gd > 0 ? `+${gd}` : gd}</span>
                <b class="font-display w-5 text-right text-[14px] tabular-nums">{row.points}</b>
              </a>
            );
          })}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
