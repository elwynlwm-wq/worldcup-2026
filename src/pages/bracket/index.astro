---
// Bracket & groups — knockout columns (from AF fixtures) + real group tables.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { getAfFixtures } from '../../lib/warehouse';
import standingsData from '../../../data-pipeline/warehouse/export/standings.json';
import Flag from '../../components/Flag.astro';

const getTeam = (id: string) => provider.getTeam(id);
const fixtures = getAfFixtures();

// The knockout tree: fixed slot count per round (16→8→4→2→1). Each round renders
// ALL its slots — a confirmed tie or a TBD placeholder — so the tree stays whole
// and the connectors line up before the draw resolves.
const ROUNDS: { stage: string; title: string; slots: number }[] = [
  { stage: 'r32', title: 'Round of 32', slots: 16 },
  { stage: 'r16', title: 'Round of 16', slots: 8 },
  { stage: 'qf', title: 'Quarter-finals', slots: 4 },
  { stage: 'sf', title: 'Semi-finals', slots: 2 },
  { stage: 'final', title: 'Final', slots: 1 },
];
const byStage = (s: string) => fixtures.filter((m) => m.stage === s && getTeam(m.homeTeamId) && getTeam(m.awayTeamId));
// pad a round's confirmed ties up to its fixed slot count with nulls (TBD)
const slotsFor = (stage: string, n: number) => {
  const ties = byStage(stage);
  return Array.from({ length: n }, (_, i) => ties[i] ?? null);
};
const dateLabel = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '');
const matchHref = (m: any) => `/matches/${m.homeTeamId}-vs-${m.awayTeamId}-${m.stage}`;

const standings = standingsData as Record<string, Array<{ rank: number; teamId: string; played: number; points: number; goalsFor: number; goalsAgainst: number; form: string }>>;
// Only the 12 real groups ("Group A".."Group L") — drop any stray aggregate key.
const groupNames = Object.keys(standings).filter((g) => /^Group [A-L]$/.test(g)).sort();
---

<BaseLayout
  title="Bracket & Groups — World Cup 2026 | Kickabout"
  description="The 2026 World Cup knockout bracket and all 12 group tables — the road to the final on 19 July."
  active="bracket"
  canonical="/bracket/"
>
  <div class="kb-route">
    <h1 class="font-display text-[34px] font-black tracking-tight">Bracket &amp; groups</h1>
    <p class="mt-0.5 mb-4 max-w-[620px] text-[15px]" style="color:var(--color-ink-2)">
      The knockout path and the group tables. Confirmed ties fill in as rounds resolve.
    </p>

    <h2 class="font-display mb-1 text-[20px] font-extrabold">The road to the final</h2>
    <p class="mb-2 text-[13px]" style="color:var(--color-ink-3)">Scroll right to follow the path to the final on 19 July.</p>
    <div class="kb-bracket">
      {ROUNDS.map(({ stage, title, slots }) => {
        const confirmed = byStage(stage).length;
        return (
          <div class="kb-round">
            <div class="kb-round-head flex items-baseline gap-2">
              <span class="font-display text-[11.5px] font-extrabold uppercase tracking-wide">{title}</span>
              <span class="text-[10.5px] font-semibold" style="color:var(--color-ink-3)">{confirmed ? `${confirmed} ties` : `${slots} ties`}</span>
            </div>
            <div class="kb-ties">
              {slotsFor(stage, slots).map((m) => {
                if (!m) {
                  return (
                    <div class="kb-tie">
                      <div class="kb-tie-card rounded-[11px] border border-dashed px-3 py-2.5" style="border-color:var(--color-line)">
                        <div class="flex items-center gap-2"><span class="h-[15px] w-[22px] flex-none rounded-[3px]" style="background:var(--color-surface-3)"></span><span class="text-[12px] font-semibold" style="color:var(--color-ink-4)">TBD</span></div>
                        <div class="my-1.5 h-px" style="background:var(--color-surface-3)"></div>
                        <div class="flex items-center gap-2"><span class="h-[15px] w-[22px] flex-none rounded-[3px]" style="background:var(--color-surface-3)"></span><span class="text-[12px] font-semibold" style="color:var(--color-ink-4)">TBD</span></div>
                      </div>
                    </div>
                  );
                }
                const h = getTeam(m.homeTeamId)!, a = getTeam(m.awayTeamId)!;
                return (
                  <div class="kb-tie">
                    <a href={matchHref(m)} class="kb-tie-card kb-card-hover rounded-[11px] border px-3 py-2.5" style="background:var(--color-surface);border-color:var(--color-line-2)">
                      <div class="mb-1.5 text-[9px] font-extrabold uppercase tracking-[.4px]" style="color:var(--color-ink-4)">{dateLabel(m.date)}</div>
                      <div class="flex items-center gap-2"><Flag team={h.id} w={22} /><b class="flex-1 text-[13px]">{h.shortCode}</b><span class="font-display text-[12px] font-extrabold">{m.homeScore ?? ''}</span></div>
                      <div class="my-1.5 h-px" style="background:var(--color-surface-3)"></div>
                      <div class="flex items-center gap-2"><Flag team={a.id} w={22} /><b class="flex-1 text-[13px]">{a.shortCode}</b><span class="font-display text-[12px] font-extrabold">{m.awayScore ?? ''}</span></div>
                    </a>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <h2 class="font-display mt-7 mb-3 text-[20px] font-extrabold">Groups</h2>
    <div class="grid gap-4" style="grid-template-columns:repeat(auto-fill,minmax(300px,1fr))">
      {groupNames.map((gname) => (
        <div class="overflow-hidden rounded-[14px] border" style="background:var(--color-surface);border-color:var(--color-line-2)">
          <div class="font-display border-b px-4 py-2.5 text-[14px] font-extrabold" style="border-color:var(--color-surface-3)">{gname}</div>
          {standings[gname].map((row, i) => {
            const t = getTeam(row.teamId);
            return (
              <a href={t ? `/teams/${t.id}/` : '#'} class="flex items-center gap-2 border-b px-4 py-2 text-[13px]" style="border-color:var(--color-surface-3)">
                <span class="w-4 text-center text-[11px] font-bold" style={`color:${i < 2 ? 'var(--color-pitch)' : 'var(--color-ink-4)'}`}>{row.rank}</span>
                <Flag team={row.teamId} w={22} />
                <b class="flex-1 truncate">{t?.name ?? row.teamId}</b>
                <span style="color:var(--color-ink-3)">{row.played}</span>
                <b class="w-6 text-right" style="color:var(--color-royal)">{row.points}</b>
              </a>
            );
          })}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
