---
// H2H evergreen page (UPCOMING) — /h2h/<a>-vs-<b>. Rebuilt to match the design:
// teams header, optional match-preview banner, Prediction / Lineups tabs.
//  - Prediction: ShowdownPanel (tap-to-pick + model reveal + forecast + factors)
//    and the all-time head-to-head.
//  - Lineups: pitch view with jersey markers, team toggle (predicted XIs).
// Data: Elo model + SofaScore votes + predicted XIs + derived H2H.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShowdownPanel from '../../components/ShowdownPanel.astro';
import PitchLineup from '../../components/PitchLineup.astro';
import { provider } from '../../lib/provider';
import { getSsPair, getSsPairKeys, getH2H } from '../../lib/warehouse';
import MatchupGraphic from '../../components/MatchupGraphic.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return getSsPairKeys().map((key) => {
    const [a, b] = key.split('__');
    return { params: { pair: `${a}-vs-${b}` }, props: { a, b } };
  });
}

const { a, b } = Astro.props;
const ta = provider.getTeam(a);
const tb = provider.getTeam(b);
if (!ta || !tb) return Astro.redirect('/teams/');

const ss = getSsPair(a, b);
// orient fan votes to a/b
let fans: { home: number; away: number } | null = null;
if (ss?.votes) {
  fans = ss.votes.homeId === a ? { home: ss.votes.home, away: ss.votes.away } : { home: ss.votes.away, away: ss.votes.home };
}

const h2h = getH2H(a, b);
const fmtDate = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { dateStyle: 'medium' }).format(new Date(iso)) : '');

const articles = await getCollection('articles', ({ data }) => !data.draft);
const preMatch = articles.find((art) => {
  const tags = (art.data.tags || []).map((t) => t.toLowerCase());
  return tags.includes(a) && tags.includes(b);
});

const luA = ss?.lineups?.[a] ?? null;
const luB = ss?.lineups?.[b] ?? null;
const hasLineups = !!(luA?.starters?.length || luB?.starters?.length);
---

<BaseLayout
  title={`${ta.name} vs ${tb.name} — Prediction, Head-to-Head & Lineups | Kickabout`}
  description={`Who wins ${ta.name} vs ${tb.name}? Our forecast, fans' who-will-win vote, predicted lineups and the all-time head-to-head record.`}
  active="matches"
  canonical={`/h2h/${a}-vs-${b}/`}
>
  <div class="kb-route">
    <div class="text-[13px] font-semibold" style="color:var(--color-ink-3)">Matchup · Head-to-head</div>

    {/* teams header — compact matchup band (larger 'heroes' art: the band is wide here) */}
    <MatchupGraphic home={ta} away={tb} vote={{ home: 1, draw: 0, away: 1 }} compact art="heroes" class="mt-1.5" />
    <div class="mt-2 flex gap-4 text-[13px] font-bold">
      <a href={`/teams/${a}/`} style="color:var(--color-royal)">{ta.name} squad</a>
      <a href={`/teams/${b}/`} style="color:var(--color-royal)">{tb.name} squad</a>
    </div>

    {/* match-preview banner */}
    {preMatch && (
      <a href={`/articles/${preMatch.id}/`} class="kb-card-hover mt-3 flex items-center gap-3.5 rounded-[14px] p-4 text-white" style="background:var(--color-pitch)">
        <span class="min-w-0 flex-1">
          <span class="font-display block text-[10.5px] font-extrabold uppercase tracking-wide" style="opacity:.85">Match preview</span>
          <span class="font-display mt-0.5 block text-[17.5px] font-extrabold leading-tight text-balance">{preMatch.data.title}</span>
        </span>
        <span class="flex-none text-[13px] font-bold" style="color:var(--color-gold)">Read the preview →</span>
      </a>
    )}

    {/* tabs — Prediction (poll + forecast) · Insights (what's behind it + all-time
        H2H + star men) · Lineups (predicted XIs). Heavy data is split per tab but
        all of it ships in the static HTML; we just show/hide client-side. */}
    <div class="mt-3.5 flex w-fit gap-1 rounded-[12px] border p-1" id="match-tabs" style="background:var(--color-surface);border-color:var(--color-line-2)">
      <button data-mtab="prediction" class="kb-mtab cursor-pointer rounded-[9px] px-4 py-2 text-[13.5px] font-bold" style="color:#fff;background:var(--color-night)">Prediction</button>
      <button data-mtab="insights" class="kb-mtab cursor-pointer rounded-[9px] px-4 py-2 text-[13.5px] font-bold" style="color:var(--color-ink-2);background:transparent">Insights</button>
      {hasLineups && <button data-mtab="lineups" class="kb-mtab cursor-pointer rounded-[9px] px-4 py-2 text-[13.5px] font-bold" style="color:var(--color-ink-2);background:transparent">Lineups</button>}
    </div>

    {/* PREDICTION — the interactive poll + forecast */}
    <section data-mpanel="prediction">
      <ShowdownPanel home={ta} away={tb} fans={fans} mode="prediction" />
    </section>

    {/* INSIGHTS — what's behind the forecast, the all-time record, star men */}
    <section data-mpanel="insights" style="display:none">
      <ShowdownPanel home={ta} away={tb} fans={fans} mode="insights" />

      <h2 class="font-display mt-7 mb-3 text-[21px] font-extrabold">Head-to-head record</h2>
      {h2h ? (
        <div class="overflow-hidden rounded-[16px] border" style="background:var(--color-night);border-color:var(--color-night)">
          <div class="grid grid-cols-3 text-center text-white">
            <div class="p-4">
              <div class="font-display text-[30px] font-black" style="color:var(--color-gold)">{h2h.aWins}</div>
              <div class="text-[12px] font-bold" style="color:var(--color-ink-3)">{ta.shortCode} wins</div>
            </div>
            <div class="border-x p-4" style="border-color:#2a2d36">
              <div class="font-display text-[30px] font-black">{h2h.draws}</div>
              <div class="text-[12px] font-bold" style="color:var(--color-ink-3)">Draws</div>
            </div>
            <div class="p-4">
              <div class="font-display text-[30px] font-black" style="color:var(--color-gold)">{h2h.bWins}</div>
              <div class="text-[12px] font-bold" style="color:var(--color-ink-3)">{tb.shortCode} wins</div>
            </div>
          </div>
          <div class="border-t px-4 py-3 text-center text-[13px]" style="border-color:#2a2d36;color:var(--color-ink-3)">
            {h2h.played} all-time meetings{h2h.lastMeeting ? ` · last ${ta.shortCode} ${h2h.lastAScore}–${h2h.lastBScore} ${tb.shortCode}, ${fmtDate(h2h.lastMeeting)}` : ''}
          </div>
        </div>
      ) : (
        <p class="text-[14.5px]" style="color:var(--color-ink-2)">{ta.name} and {tb.name} have no recorded all-time meetings.</p>
      )}
    </section>

    {/* LINEUPS */}
    {hasLineups && (
      <section data-mpanel="lineups" style="display:none">
        <p class="mt-4 mb-3 text-[13.5px]" style="color:var(--color-ink-2)">No confirmed XI yet — these are the most likely teams based on recent selection.</p>
        <div class="mb-3.5 flex justify-center gap-2" id="lineup-toggle">
          {luA && <button data-lteam={a} class="kb-lteam cursor-pointer rounded-full px-[18px] py-2 text-[13.5px] font-extrabold" style={`border:1.5px solid ${'var(--color-pitch)'};color:#fff;background:var(--color-pitch)`}>{ta.name}</button>}
          {luB && <button data-lteam={b} class="kb-lteam cursor-pointer rounded-full px-[18px] py-2 text-[13.5px] font-extrabold" style="border:1.5px solid var(--color-line);color:var(--color-ink-2);background:#fff">{tb.name}</button>}
        </div>
        {luA && <div data-lpitch={a}><PitchLineup team={ta} lineup={luA} /></div>}
        {luB && <div data-lpitch={b} style="display:none"><PitchLineup team={tb} lineup={luB} /></div>}
      </section>
    )}

    <div class="mt-5 flex gap-5">
      <a href={`/teams/${a}/`} class="text-sm font-bold" style="color:var(--color-royal)">{ta.name} squad →</a>
      <a href={`/teams/${b}/`} class="text-sm font-bold" style="color:var(--color-royal)">{tb.name} squad →</a>
    </div>
  </div>

  <script is:inline>
    (() => {
      // match tabs
      const tabs = document.querySelectorAll('#match-tabs .kb-mtab');
      const panels = document.querySelectorAll('[data-mpanel]');
      tabs.forEach((t) => t.addEventListener('click', () => {
        const name = t.getAttribute('data-mtab');
        panels.forEach((p) => (p.style.display = p.getAttribute('data-mpanel') === name ? '' : 'none'));
        tabs.forEach((x) => { const on = x === t; x.style.color = on ? '#fff' : 'var(--color-ink-2)'; x.style.background = on ? 'var(--color-night)' : 'transparent'; });
      }));
      // lineup team toggle
      const lt = document.querySelectorAll('#lineup-toggle .kb-lteam');
      lt.forEach((btn) => btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-lteam');
        document.querySelectorAll('[data-lpitch]').forEach((p) => (p.style.display = p.getAttribute('data-lpitch') === id ? '' : 'none'));
        lt.forEach((x) => {
          const on = x === btn;
          x.style.color = on ? '#fff' : 'var(--color-ink-2)';
          x.style.background = on ? 'var(--color-pitch)' : '#fff';
          x.style.borderColor = on ? 'var(--color-pitch)' : 'var(--color-line)';
        });
      }));
    })();
  </script>
</BaseLayout>
