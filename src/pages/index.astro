---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamMark from '../components/TeamMark.astro';
import ProbBar from '../components/analysis/ProbBar.astro';
import Showdown from '../components/Showdown.tsx';
import { getCollection } from 'astro:content';
import { provider } from '../lib/provider';
import { predict } from '../lib/model';
import { teamColors } from '../data/teamColors';

const fixtures = provider.getFixtures().filter((m) => m.stage === 'r32');
const FAN = [21, 68, 57, 63]; // illustrative fan splits (home %) per confirmed tie

const hero = fixtures[0];
const hHome = provider.getTeam(hero.homeTeamId)!;
const hAway = provider.getTeam(hero.awayTeamId)!;
const hPr = predict(hHome, hAway);
const [hc1, hc2] = teamColors(hHome.id);
const [ac1, ac2] = teamColors(hAway.id);

const contenders = provider
  .getTeams()
  .slice()
  .sort((a, b) => b.adjRating - a.adjRating)
  .slice(0, 6);

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const latest = articles[0];

const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmt = (iso: string) => { const [, m, d] = iso.split('-'); return `${+d} ${MON[+m - 1]}`; };
const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Kickabout — World Cup 2026', url: Astro.site?.href,
};
---

<BaseLayout
  title="Kickabout — World Cup 2026 Predictions, Analysis & Stories"
  description="Predict every 2026 World Cup match, see who the model favours, and read match previews and analysis. A free, entertaining read for every kind of fan."
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-4">
    <section class="pt-8">
      <div
        class="relative flex items-center gap-6 overflow-hidden rounded-2xl border border-line p-6 md:p-8"
        style="background:radial-gradient(130% 170% at 6% -10%, rgba(255,210,63,.18), transparent 46%), radial-gradient(130% 170% at 104% 120%, rgba(232,72,43,.22), transparent 52%), linear-gradient(180deg,#1c1f27,#181a21)"
      >
        <svg class="hidden h-[72px] w-[72px] shrink-0 md:block" viewBox="0 0 32 32" aria-hidden="true">
          <circle cx="16" cy="16" r="15" fill="#f6f4ee"></circle>
          <path d="M16 5.4l6.4 4.7-2.45 7.5h-7.9l-2.45-7.5z" fill="#15171c"></path>
          <g fill="none" stroke="#15171c" stroke-width="1.5">
            <path d="M16 5.4V1.4"></path><path d="M22.4 10.1l4.5-2.2"></path>
            <path d="M19.95 17.6l4.6 3M12.05 17.6l-4.6 3"></path><path d="M9.6 10.1L5.1 7.9"></path>
          </g>
          <circle cx="16" cy="16" r="15" fill="none" stroke="#15171c" stroke-width="1.3"></circle>
        </svg>
        <div>
          <div class="font-display text-xs font-extrabold uppercase tracking-[0.14em] text-ball">
            World Cup 2026 · 48 teams
          </div>
          <h1 class="mt-1 font-display text-4xl font-black leading-[0.96] tracking-tight md:text-5xl">
            16 down. <span class="text-ball">32 to go.</span>
          </h1>
          <p class="mt-2 max-w-xl text-[15px] text-muted">
            The knockouts kick off this weekend across three host nations. Call the winners before
            the model does.
          </p>
          <div class="mt-3.5 flex flex-wrap gap-2">
            <span class="flex items-center gap-1.5 rounded-full border border-line bg-black/25 px-2.5 py-1 font-display text-[11.5px] font-bold">
              <span class="h-2 w-2 rounded-full" style="background:#3c3b6e"></span>United States
            </span>
            <span class="flex items-center gap-1.5 rounded-full border border-line bg-black/25 px-2.5 py-1 font-display text-[11.5px] font-bold">
              <span class="h-2 w-2 rounded-full" style="background:#d52b1e"></span>Canada
            </span>
            <span class="flex items-center gap-1.5 rounded-full border border-line bg-black/25 px-2.5 py-1 font-display text-[11.5px] font-bold">
              <span class="h-2 w-2 rounded-full" style="background:#006847"></span>Mexico
            </span>
          </div>
        </div>
      </div>
    </section>

    <div class="mt-8 mb-3 font-display text-xs font-extrabold uppercase tracking-[0.12em] text-muted">
      This weekend
    </div>

    <section class="grid gap-4 md:grid-cols-2">
      <Showdown
        client:load
        home={{ id: hHome.id, name: hHome.name, code: hHome.shortCode, c1: hc1, c2: hc2 }}
        away={{ id: hAway.id, name: hAway.name, code: hAway.shortCode, c1: ac1, c2: ac2 }}
        win={hPr.win}
        draw={hPr.draw}
        lose={hPr.lose}
        fanHome={FAN[0]}
        date={fmt(hero.kickoff.slice(0, 10))}
        city={hero.city ?? ''}
        venue={hero.venue ?? ''}
        predictHref={`/analysis/predict/?a=${hHome.id}&b=${hAway.id}`}
      />
      <a
        href={latest ? `/articles/${latest.id}/` : '/articles'}
        class="relative flex min-h-[300px] flex-col justify-end overflow-hidden rounded-2xl p-6"
        style="background:radial-gradient(120% 120% at 100% 0%, #f0632e 0%, #d8381f 42%, #7a1f12 100%)"
      >
        <div class="font-display text-[12px] font-extrabold uppercase tracking-[0.1em] text-white/85">
          The big picture
        </div>
        <h2 class="mt-2 font-display text-3xl font-black leading-[1.05] text-white">
          {latest ? latest.data.title : '16 down, 32 to go: where the World Cup stands'}
        </h2>
        <p class="mt-2.5 max-w-[44ch] text-white/90">
          {latest
            ? latest.data.description
            : 'Half the groups are locked, the giants are circling, and the knockouts start this weekend.'}
        </p>
        <div class="mt-3 font-display font-extrabold text-white">Read the story →</div>
      </a>
    </section>

    <h2 class="mt-9 mb-3 font-display text-xl font-extrabold tracking-tight">More ties this weekend</h2>
    <div class="grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
      {fixtures.map((m) => {
        const h = provider.getTeam(m.homeTeamId)!;
        const a = provider.getTeam(m.awayTeamId)!;
        const pr = predict(h, a);
        return (
          <a
            href={`/analysis/predict/?a=${h.id}&b=${a.id}`}
            class="rounded-2xl border border-line bg-panel p-4 transition hover:-translate-y-0.5 hover:border-ball"
          >
            <div class="font-display text-[11px] font-extrabold uppercase tracking-[0.08em] text-muted">
              {fmt(m.kickoff.slice(0, 10))} · Round of 32
            </div>
            <div class="my-3 flex items-center justify-between font-display font-extrabold">
              <span class="flex items-center gap-2"><TeamMark id={h.id} size={26} /> {h.shortCode}</span>
              <span class="flex items-center gap-2">{a.shortCode} <TeamMark id={a.id} size={26} /></span>
            </div>
            <ProbBar home={h} away={a} pr={pr} />
          </a>
        );
      })}
    </div>

    <h2 class="mt-9 mb-3 font-display text-xl font-extrabold tracking-tight">Title contenders</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {contenders.map((t) => (
        <a
          href={`/analysis/teams/${t.id}/`}
          class="flex items-center gap-3 rounded-2xl border border-line bg-panel p-3.5 hover:border-ball"
        >
          <TeamMark id={t.id} size={34} />
          <div>
            <div class="font-display font-extrabold">{t.name}</div>
            <div class="text-[12px] text-muted">Elo {t.elo} · FIFA #{t.fifaRank}</div>
          </div>
        </a>
      ))}
    </div>

    {articles.length > 0 && (
      <>
        <h2 class="mt-9 mb-3 font-display text-xl font-extrabold tracking-tight">Latest</h2>
        <ul class="grid gap-4 pb-4 sm:grid-cols-2">
          {articles.map((a) => (
            <li class="rounded-2xl border border-line bg-panel p-5 transition hover:border-ball">
              <a href={`/articles/${a.id}/`} class="block">
                <h3 class="font-display text-xl font-bold text-ink">{a.data.title}</h3>
                <p class="mt-2 text-muted">{a.data.description}</p>
                <time datetime={a.data.publishDate.toISOString()} class="mt-3 block text-sm text-muted">
                  {dateFmt.format(a.data.publishDate)}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}
  </div>
</BaseLayout>
