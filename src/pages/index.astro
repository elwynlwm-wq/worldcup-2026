---
// Home = Predict. The predictor is the product: call each upcoming tie, see the
// model AND the market in the same tile, plus who the market backs to win it all.
import BaseLayout from '../layouts/BaseLayout.astro';
import Flag from '../components/Flag.astro';
import PredictBoard from '../components/PredictBoard.tsx';
import type { Tie } from '../components/PredictBoard.tsx';
import { provider } from '../lib/provider';
import { predict } from '../lib/model';
import { getUpcomingFixtures, getOddsPair } from '../lib/warehouse';
import { MARKET_OUTRIGHT, MARKET_ASOF } from '../data/market';

const getTeam = (id: string) => provider.getTeam(id);
const stageLabel: Record<string, string> = { group: 'Group', r32: 'Round of 32', r16: 'Round of 16', qf: 'Quarter-final', sf: 'Semi-final', final: 'Final', third_place: '3rd place' };
const dateLabel = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '');

function marketPct(hId: string, aId: string) {
  const op = getOddsPair(hId, aId);
  if (!op || !op.books?.length) return null;
  let H = 0, D = 0, A = 0;
  for (const b of op.books) { const ih = 1 / b.home, id = 1 / b.draw, ia = 1 / b.away; const s = ih + id + ia; H += ih / s; D += id / s; A += ia / s; }
  const n = op.books.length; let h = H / n, d = D / n, a = A / n;
  if (op.homeId !== hId) { const t = h; h = a; a = t; }
  return { h: Math.round(h * 100), d: Math.round(d * 100), a: Math.round(a * 100) };
}

const fixtures = getUpcomingFixtures(10).filter((m) => getTeam(m.homeTeamId) && getTeam(m.awayTeamId));
const ties: Tie[] = fixtures.map((m) => {
  const h = getTeam(m.homeTeamId)!, a = getTeam(m.awayTeamId)!;
  const pr = predict(h, a);
  const k = marketPct(h.id, a.id);
  return {
    home: { id: h.id, name: h.name, code: h.shortCode }, away: { id: a.id, name: a.name, code: a.shortCode },
    mh: Math.round(pr.win * 100), md: Math.round(pr.draw * 100), ma: Math.round(pr.lose * 100),
    kh: k ? k.h : null, kd: k ? k.d : null, ka: k ? k.a : null,
    date: dateLabel(m.date), stage: stageLabel[m.stage] ?? m.stage,
  };
});

const outright = MARKET_OUTRIGHT.map((r) => ({ ...r, team: getTeam(r.id) })).filter((r) => r.team);
const maxBook = Math.max(...outright.map((r) => r.book));
---

<BaseLayout
  title="World Cup Analytics — Predict the 2026 World Cup"
  description="Call every 2026 World Cup knockout tie and see how you stack up against a transparent model and the betting market — plus who the market backs to win it all."
  active=""
  canonical="/"
>
  <div class="kb-route">
    <h1 class="font-display" style="font-size:38px;font-weight:900;letter-spacing:-1.2px;line-height:1.02">Predict the World Cup</h1>
    <p style="color:#6f6655;font-size:15px;max-width:52ch">Call every knockout tie, then see the model's forecast and the market's, right in the same card. Can you beat them both?</p>

    <div style="margin-top:22px">
      <PredictBoard client:load ties={ties} />
      <p style="margin-top:8px;font-size:12px;color:var(--color-ink-3)">Model: transparent Elo forecast. Market: live bookmaker consensus. Not betting advice. · <a href="/articles" style="color:var(--color-royal);font-weight:700">Read the stories →</a></p>
    </div>

    <div style="margin-top:34px;display:flex;flex-wrap:wrap;align-items:baseline;justify-content:space-between;gap:8px">
      <h2 class="font-display" style="font-size:20px;font-weight:800;letter-spacing:-.5px">The market's call — who lifts the trophy?</h2>
      <span style="font-size:12px;color:var(--color-ink-3)">implied odds · snapshot {MARKET_ASOF}</span>
    </div>
    <div style="margin-top:10px;border:1px solid var(--color-line);border-radius:16px;overflow:hidden;background:#fff">
      <table style="width:100%;border-collapse:collapse;font-size:14px">
        <thead>
          <tr style="text-align:left;border-bottom:1px solid var(--color-line);color:var(--color-ink-3)">
            <th class="font-display" style="padding:11px 16px;font-size:12px;text-transform:uppercase;letter-spacing:.4px">Team</th>
            <th class="font-display" style="padding:11px 12px;text-align:right;font-size:12px;text-transform:uppercase;letter-spacing:.4px">Bookmakers</th>
            <th class="font-display" style="padding:11px 12px;text-align:right;font-size:12px;text-transform:uppercase;letter-spacing:.4px">Polymarket</th>
            <th class="font-display" style="padding:11px 12px;text-align:right;font-size:12px;text-transform:uppercase;letter-spacing:.4px">Kalshi</th>
          </tr>
        </thead>
        <tbody>
          {outright.map((r) => (
            <tr style="border-bottom:1px solid var(--color-line)">
              <td style="padding:9px 16px">
                <a href={`/teams/${r.id}`} class="font-display" style="display:flex;align-items:center;gap:10px;font-weight:700"><Flag team={r.id} w={22} /> {r.team!.name}</a>
              </td>
              <td style="padding:9px 12px">
                <div style="display:flex;align-items:center;justify-content:flex-end;gap:8px">
                  <span style={`display:inline-block;height:6px;border-radius:3px;background:var(--color-gold);width:${Math.round((r.book / maxBook) * 90)}px`}></span>
                  <b class="font-display" style="width:44px;text-align:right;display:inline-block">{r.book}%</b>
                </div>
              </td>
              <td style="padding:9px 12px;text-align:right;color:var(--color-ink-2)">{r.polymarket != null ? r.polymarket + '%' : '—'}</td>
              <td style="padding:9px 12px;text-align:right;color:var(--color-ink-2)">{r.kalshi != null ? r.kalshi + '%' : '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p style="margin-top:8px;font-size:12px;color:var(--color-ink-3)">Bookmaker consensus vs prediction markets (Polymarket, Kalshi). Outright snapshot — a live feed can replace it later.</p>
  </div>
</BaseLayout>
