---
// Home — ported from the design. Three "how to follow" tabs: Today / Stories /
// Pulse (toggled client-side; all content is in the HTML for SEO). Wires real
// warehouse data: next matches + who-will-win votes (Showdown), power ranking,
// tournament stats, and articles.
import BaseLayout from '../layouts/BaseLayout.astro';
import { provider } from '../lib/provider';
import { predict } from '../lib/model';
import { getUpcomingFixtures, getSsPair } from '../lib/warehouse';
import Flag from '../components/Flag.astro';
import MatchupGraphic from '../components/MatchupGraphic.astro';
import { getCollection } from 'astro:content';

const teamName = (id: string) => provider.getTeam(id)?.name ?? id;
const teamCode = (id: string) => provider.getTeam(id)?.shortCode ?? '';
const getTeam = (id: string) => provider.getTeam(id)!;

const upcoming = getUpcomingFixtures(6);
const top = provider.getTeams().slice().sort((a, b) => b.adjRating - a.adjRating);
const powerTop = top.slice(0, 8);

// "Today" feature match = first upcoming with both teams known
const todayMatch = upcoming.find((m) => getTeam(m.homeTeamId) && getTeam(m.awayTeamId)) ?? null;

// fav line for an upcoming fixture
const favLine = (homeId: string, awayId: string) => {
  const h = getTeam(homeId), a = getTeam(awayId);
  if (!h || !a) return '';
  const pr = predict(h, a);
  const fav = pr.win >= pr.lose ? h : a;
  return `${fav.name} favoured · ${Math.round(Math.max(pr.win, pr.lose) * 100)}%`;
};

const pct = (homeId: string, awayId: string) => {
  const h = getTeam(homeId), a = getTeam(awayId);
  if (!h || !a) return { win: 33, draw: 34, lose: 33 };
  const pr = predict(h, a);
  return { win: Math.round(pr.win * 100), draw: Math.round(pr.draw * 100), lose: Math.round(pr.lose * 100) };
};

// who-wins split for the matchup graphic: prefer real fan votes, else the model.
const voteSplit = (homeId: string, awayId: string) => {
  const ss = getSsPair(homeId, awayId);
  if (ss?.votes) {
    const v = ss.votes;
    const [home, away] = v.homeId === homeId ? [v.home, v.away] : [v.away, v.home];
    return { vote: { home, draw: v.draw, away }, source: 'Fan vote' };
  }
  const p = pct(homeId, awayId);
  return { vote: p, source: 'Our forecast' };
};

const dateLabel = (iso: string) =>
  iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '';
const stageLabel: Record<string, string> = { group: 'Group', r32: 'Round of 32', r16: 'Round of 16', qf: 'Quarter-final', sf: 'Semi-final', final: 'Final', third_place: '3rd place' };

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featured = articles[0] ?? null;

const jsonLd = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Kickabout', url: Astro.site?.href };
---

<BaseLayout
  title="Kickabout — World Cup 2026 Predictions, Analysis & Stories"
  description="Follow the 2026 World Cup your way: today's matches and who-will-win votes, data-driven analysis, power rankings, and stories for every kind of fan."
  active=""
  jsonLd={jsonLd}
>
  <div class="kb-route">
    {/* header + tabs */}
    <div class="mb-1.5 flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="font-display text-[13px] font-extrabold uppercase tracking-[1.5px]" style="color:var(--color-royal)">
          World Cup 2026 · USA · Canada · Mexico
        </div>
        <div class="mt-0.5 text-sm" style="color:var(--color-ink-2)">Pick how you like to follow along.</div>
      </div>
      <div id="home-tabs" class="flex gap-1 rounded-[12px] border p-1" style="background:#fff;border-color:var(--color-line)">
        {[['today', 'Today'], ['stories', 'Stories']].map(([k, label], i) => (
          <button data-tab={k} class:list={['kb-tab cursor-pointer rounded-[9px] px-3.5 py-2 text-[13.5px] font-bold']} style={i === 0 ? 'color:#fff;background:var(--color-night)' : 'color:var(--color-ink-2);background:transparent'}>{label}</button>
        ))}
      </div>
    </div>

    {/* ============ TODAY ============ */}
    <section data-panel="today">
      <div class="my-3.5 grid gap-4 lg:grid-cols-[1.4fr_1fr]">
        {todayMatch && (() => {
          const h = getTeam(todayMatch.homeTeamId), a = getTeam(todayMatch.awayTeamId);
          const { vote, source } = voteSplit(h.id, a.id);
          const label = [stageLabel[todayMatch.stage], dateLabel(todayMatch.date), todayMatch.venue]
            .filter(Boolean).join(' · ');
          return (
            <MatchupGraphic home={h} away={a} vote={vote} voteSource={source} label={label} href={`/matches/${h.id}-vs-${a.id}-${todayMatch.stage}`} />
          );
        })()}
        {featured && (
          <a href={`/articles/${featured.id}/`} class="kb-card-hover relative flex min-h-[230px] flex-col justify-end overflow-hidden rounded-[20px] p-6 text-white" style="background:var(--color-night)">
            <img src={`/banners/blog/${featured.id}.jpg`} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" onerror="this.remove()" />
            <div class="absolute inset-0" style="background:linear-gradient(105deg,rgba(8,9,12,.92) 0%,rgba(8,9,12,.72) 38%,rgba(8,9,12,.18) 72%,rgba(8,9,12,0) 100%)"></div>
            <div class="relative">
              <div class="font-display inline-block self-start rounded border-[1.5px] px-2.5 py-1 text-[11px] font-extrabold uppercase tracking-[1.2px]" style="border-color:rgba(255,255,255,.5)">Story</div>
              <div class="font-display mt-2.5 text-[25px] font-black leading-tight tracking-tight text-balance">{featured.data.title}</div>
              <div class="mt-2 text-[14.5px] leading-snug" style="font-family:var(--font-serif);opacity:.92">{featured.data.description}</div>
              <div class="mt-3 text-xs font-bold" style="color:var(--color-gold)">READ THE STORY →</div>
            </div>
          </a>
        )}
      </div>

      <h2 class="font-display mb-3 text-[20px] font-extrabold">More ties this weekend</h2>
      <div class="grid gap-3.5" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr))">
        {upcoming.map((m) => {
          const h = getTeam(m.homeTeamId), a = getTeam(m.awayTeamId);
          if (!h || !a) return null;
          const p = pct(h.id, a.id);
          return (
            <a href={`/matches/${h.id}-vs-${a.id}-${m.stage}`} class="kb-card-hover block rounded-[14px] border p-4" style="background:var(--color-surface);border-color:var(--color-line-2)">
              <div class="text-[11px] font-bold uppercase tracking-[.6px]" style="color:var(--color-ink-3)">{dateLabel(m.date)} · {stageLabel[m.stage]}</div>
              <div class="mt-2.5 flex items-center justify-between">
                <div class="flex items-center gap-1.5"><Flag team={h.id} w={26} /><b>{h.shortCode}</b></div>
                <span class="text-xs font-bold" style="color:var(--color-ink-4)">vs</span>
                <div class="flex items-center gap-1.5"><b>{a.shortCode}</b><Flag team={a.id} w={26} /></div>
              </div>
              <div class="mt-2.5 flex h-[9px] overflow-hidden rounded-md">
                <span style={`width:${p.win}%;background:var(--color-royal)`}></span><span style={`width:${p.draw}%;background:#d8cfbf`}></span><span style={`width:${p.lose}%;background:#2b2e36`}></span>
              </div>
              <div class="mt-2 text-xs font-bold" style="color:var(--color-ink-2)">{favLine(h.id, a.id)}</div>
            </a>
          );
        })}
      </div>

      <div class="mt-7 mb-3 flex items-baseline justify-between">
        <h2 class="font-display text-[20px] font-extrabold">Power top 8</h2>
        <a href="/power" class="text-[13.5px] font-bold" style="color:var(--color-royal)">Full ranking →</a>
      </div>
      <div class="overflow-hidden rounded-[14px] border" style="background:var(--color-surface);border-color:var(--color-line-2)">
        {powerTop.map((t, i) => (
          <a href={`/teams/${t.id}/`} class="flex items-center gap-3 border-b px-4 py-2.5" style="border-color:var(--color-surface-3)">
            <span class="font-display w-5 text-[15px] font-black" style="color:var(--color-ink-4)">{i + 1}</span>
            <Flag team={t.id} w={28} />
            <b class="flex-1 text-[14.5px]">{t.name}</b>
            <span class="font-display text-[16px] font-black" style="color:var(--color-royal)">{t.strength}</span>
          </a>
        ))}
      </div>
    </section>

    {/* ============ STORIES ============ */}
    <section data-panel="stories" style="display:none">
      {featured && (
        <a href={`/articles/${featured.id}/`} class="kb-card-hover relative mb-6 flex min-h-[260px] flex-col justify-end overflow-hidden rounded-[20px] p-8 text-white" style="background:var(--color-night)">
          <img src={`/banners/blog/${featured.id}.jpg`} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" onerror="this.remove()" />
          <div class="absolute inset-0" style="background:linear-gradient(105deg,rgba(8,9,12,.92) 0%,rgba(8,9,12,.7) 42%,rgba(8,9,12,.12) 78%,rgba(8,9,12,0) 100%)"></div>
          <div class="relative">
            <div class="font-display inline-block rounded border-[1.5px] px-2.5 py-1 text-[11.5px] font-extrabold uppercase tracking-[1.4px]" style="border-color:rgba(255,255,255,.5)">Featured</div>
            <div class="font-display mt-4 max-w-[680px] text-[40px] font-black leading-[1.02] tracking-tight text-balance">{featured.data.title}</div>
            <div class="mt-2.5 max-w-[600px] text-[18px] leading-relaxed" style="font-family:var(--font-serif);opacity:.93">{featured.data.description}</div>
            <div class="mt-4 text-[13px] font-bold" style="color:var(--color-gold)">READ THE STORY →</div>
          </div>
        </a>
      )}
      <h2 class="font-display mb-3 text-[22px] font-extrabold">Latest stories</h2>
      {articles.length <= 1 ? (
        <p style="color:var(--color-ink-2)">More stories on the way — check back soon.</p>
      ) : (
        <div class="grid gap-4" style="grid-template-columns:repeat(auto-fill,minmax(290px,1fr))">
          {articles.map((s) => (
            <a href={`/articles/${s.id}/`} class="kb-card-hover flex flex-col rounded-[16px] border p-4" style="background:var(--color-surface);border-color:var(--color-line-2)">
              <div class="font-display text-[18.5px] font-extrabold leading-tight tracking-tight text-balance">{s.data.title}</div>
              <div class="mt-2 flex-1 text-sm leading-snug" style="color:var(--color-ink-2)">{s.data.description}</div>
            </a>
          ))}
        </div>
      )}
    </section>

  </div>

  <script is:inline>
    (() => {
      const tabs = document.querySelectorAll('#home-tabs .kb-tab');
      const panels = document.querySelectorAll('[data-panel]');
      const night = 'var(--color-night)';
      function show(name) {
        panels.forEach((p) => (p.style.display = p.getAttribute('data-panel') === name ? '' : 'none'));
        tabs.forEach((t) => {
          const on = t.getAttribute('data-tab') === name;
          t.style.color = on ? '#fff' : 'var(--color-ink-2)';
          t.style.background = on ? night : 'transparent';
        });
      }
      tabs.forEach((t) => t.addEventListener('click', () => show(t.getAttribute('data-tab'))));
    })();
  </script>
</BaseLayout>
