---
// TEMP home during the design port — links to ported pages for review.
// Replaced by the real ported Home in a later step.
import BaseLayout from '../layouts/BaseLayout.astro';
const withBanners = ['brazil', 'argentina', 'japan', 'morocco'];
---

<BaseLayout title="Kickabout — World Cup 2026" description="Predictions, analysis and stories for the 2026 World Cup." active="">
  <div class="kb-route">
    <h1 class="font-display text-3xl font-black">Port in progress</h1>
    <p class="mt-2" style="color:var(--color-ink-2)">Team pages (with hero banners) ready to review:</p>
    <div class="mt-4 grid gap-3" style="grid-template-columns:repeat(auto-fill,minmax(180px,1fr))">
      {withBanners.map((id) => (
        <a href={`/teams/${id}/`} class="kb-card-hover rounded-[14px] border p-4 font-bold" style="background:var(--color-surface);border-color:var(--color-line-2)">
          {id} →
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
