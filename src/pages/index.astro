---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Latest published articles for the home feed.
const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'World Cup 2026',
  url: Astro.site?.href,
};

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
---

<BaseLayout
  title="World Cup 2026 — Predictions, Analysis & Blog"
  description="Predictions, analysis, match previews and reviews for the 2026 World Cup. The free, entertaining read for every fan — from curious newcomers to seasonal watchers."
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-5xl font-extrabold tracking-tight text-balance">
      Your guide to the 2026 World Cup
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-gray-600">
      Predictions, analysis and stories — written to be useful whether you watch every
      match or just want to know who'll win.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-12">
    <h2 class="mb-6 text-2xl font-bold tracking-tight">Latest</h2>
    {articles.length === 0 ? (
      <p class="text-gray-500">No articles yet — the first ones are on the way.</p>
    ) : (
      <ul class="grid gap-6 sm:grid-cols-2">
        {articles.map((a) => (
          <li class="rounded-xl border border-gray-200 p-5 transition hover:border-gray-400">
            <a href={`/articles/${a.id}/`} class="block">
              <h3 class="text-xl font-bold tracking-tight">{a.data.title}</h3>
              <p class="mt-2 text-gray-600">{a.data.description}</p>
              <time
                datetime={a.data.publishDate.toISOString()}
                class="mt-3 block text-sm text-gray-400"
              >
                {dateFmt.format(a.data.publishDate)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
