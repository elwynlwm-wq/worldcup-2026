---
// Match record page (PLAYED) — /matches/<a>-vs-<b>-<stage>.
// Archival record of a finished match: final score, goalscorers, post-match
// articles. (Full xG/stats/events export is a follow-up; data is in the
// warehouse.) One page per finished fixture. See docs/port-plan.md.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { getRecentResults, getMatchGoals, getH2H } from '../../lib/warehouse';
import { teamGrad } from '../../data/teamColors';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  // One page per finished AF fixture with both teams mapped.
  return getRecentResults(200)
    .filter((m) => provider.getTeam(m.homeTeamId) && provider.getTeam(m.awayTeamId))
    .map((m) => ({
      params: { id: `${m.homeTeamId}-vs-${m.awayTeamId}-${m.stage}` },
      props: { m },
    }));
}

const { m } = Astro.props;
const h = provider.getTeam(m.homeTeamId)!;
const a = provider.getTeam(m.awayTeamId)!;
// goalscorers (from openfootball, keyed by wc-match id — best-effort match by teams)
const goals = getMatchGoals(`wc-${m.id}`); // af id won't match wc id; left for follow-up
const h2h = getH2H(h.id, a.id);

const stageLabel: Record<string, string> = { group: 'Group stage', r32: 'Round of 32', r16: 'Round of 16', qf: 'Quarter-final', sf: 'Semi-final', final: 'Final', third_place: 'Third place' };
const fmtDate = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(new Date(iso)) : '');

const articles = await getCollection('articles', ({ data }) => !data.draft);
const related = articles.filter((art) => {
  const tags = (art.data.tags || []).map((t) => t.toLowerCase());
  return tags.includes(h.id) && tags.includes(a.id);
});

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'SportsEvent',
  name: `${h.name} vs ${a.name}`, sport: 'Football',
  ...(m.date ? { startDate: m.date } : {}),
  ...(m.venue ? { location: { '@type': 'Place', name: m.venue } } : {}),
  competitor: [
    { '@type': 'SportsTeam', name: h.name },
    { '@type': 'SportsTeam', name: a.name },
  ],
};
---

<BaseLayout
  title={`${h.name} ${m.homeScore}–${m.awayScore} ${a.name} — World Cup 2026 | Kickabout`}
  description={`${h.name} ${m.homeScore}–${m.awayScore} ${a.name}, ${stageLabel[m.stage]} at the 2026 World Cup. Result, head-to-head and post-match reads.`}
  active="matches"
  canonical={`/matches/${h.id}-vs-${a.id}-${m.stage}/`}
  jsonLd={jsonLd}
>
  <div class="kb-route">
    <div class="text-[13px] font-semibold" style="color:var(--color-ink-3)">
      {stageLabel[m.stage]}{m.venue ? ` · ${m.venue}` : ''}{m.date ? ` · ${fmtDate(m.date)}` : ''}
    </div>

    {/* scoreline */}
    <div class="mt-2 flex items-center gap-4 rounded-[14px] border p-5" style="background:var(--color-surface);border-color:var(--color-line-2)">
      <div class="flex min-w-0 flex-1 items-center gap-3">
        <span class="h-7 w-10 flex-none rounded-[5px]" style={`background:${teamGrad(h.id)};box-shadow:inset 0 0 0 1px rgba(0,0,0,.14)`}></span>
        <b class="font-display text-[18px] tracking-tight">{h.name}</b>
      </div>
      <div class="font-display flex-none px-2 text-[28px] font-black">{m.homeScore}–{m.awayScore}</div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-3">
        <b class="font-display text-right text-[18px] tracking-tight">{a.name}</b>
        <span class="h-7 w-10 flex-none rounded-[5px]" style={`background:${teamGrad(a.id)};box-shadow:inset 0 0 0 1px rgba(0,0,0,.14)`}></span>
      </div>
    </div>

    {goals.length > 0 && (
      <div class="mt-4 rounded-[14px] border p-4" style="background:var(--color-surface);border-color:var(--color-line-2)">
        <div class="font-display mb-2 text-center text-[11px] font-extrabold uppercase tracking-wide" style="color:var(--color-ink-3)">⚽ Goals</div>
        <ul class="text-sm">
          {goals.map((g) => (<li>{g.scorer} <span style="color:var(--color-ink-3)">{g.minute}'</span></li>))}
        </ul>
      </div>
    )}

    {h2h && (
      <p class="mt-4 text-sm" style="color:var(--color-ink-2)">
        All-time: {h.shortCode} {h2h.aWins}W · {h2h.draws}D · {a.shortCode} {h2h.bWins}W (over {h2h.played} meetings).
      </p>
    )}

    <p class="mt-4 text-[13px]" style="color:var(--color-ink-3)">
      Full match stats (possession, shots, xG) and lineups are in the warehouse — wiring to this
      page is a follow-up.
    </p>

    {related.length > 0 && (
      <div class="mt-6">
        <h2 class="font-display mb-3 text-[19px] font-extrabold">Post-match reads</h2>
        <div class="grid gap-3.5" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr))">
          {related.map((art) => (
            <a href={`/articles/${art.id}/`} class="kb-card-hover rounded-[14px] border p-4" style="background:var(--color-surface);border-color:var(--color-line-2)">
              <div class="font-display text-[17px] font-extrabold leading-tight text-balance">{art.data.title}</div>
              <div class="mt-1.5 text-[13.5px]" style="color:var(--color-ink-2)">{art.data.description}</div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
