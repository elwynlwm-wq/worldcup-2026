---
// Matches — rebuilt pixel-faithfully from claude-design Kickabout.dc.html.
// Upcoming ties (forecast bar) + recent results, 2-tone swatches throughout.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { predict } from '../../lib/model';
import { getUpcomingFixtures, getRecentResults } from '../../lib/warehouse';
import Flag from '../../components/Flag.astro';

const getTeam = (id: string) => provider.getTeam(id)!;
const upcoming = getUpcomingFixtures(12).filter((m) => getTeam(m.homeTeamId) && getTeam(m.awayTeamId));
const recent = getRecentResults(20).filter((m) => getTeam(m.homeTeamId) && getTeam(m.awayTeamId));

const dateLabel = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '');
const stageLabel: Record<string, string> = { group: 'Group', r32: 'Round of 32', r16: 'Round of 16', qf: 'Quarter-final', sf: 'Semi-final', final: 'Final', third_place: '3rd place' };
const matchSlug = (m: { homeTeamId: string; awayTeamId: string; stage: string }) => `${m.homeTeamId}-vs-${m.awayTeamId}-${m.stage}`;

const fc = (hId: string, aId: string) => {
  const h = getTeam(hId), a = getTeam(aId);
  const pr = predict(h, a);
  const fav = pr.win >= pr.lose ? h : a;
  return { win: Math.round(pr.win * 100), draw: Math.round(pr.draw * 100), lose: Math.round(pr.lose * 100), line: `${fav.name} favoured · ${Math.round(Math.max(pr.win, pr.lose) * 100)}%` };
};
const nextStage = upcoming[0] ? stageLabel[upcoming[0].stage] : 'Knockouts';
---

<BaseLayout
  title="Matches — World Cup 2026 | Kickabout"
  description="2026 World Cup fixtures and results: what's next, what just happened, and who we think wins."
  active="matches"
  canonical="/matches/"
>
  <div class="kb-route">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="font-display text-[34px] font-black tracking-[-1px]">Matches</h1>
        <p class="text-[15px]" style="color:#6f6655">What's next, what just happened, and who we think wins.</p>
      </div>
    </div>

    {upcoming.length > 0 && (
      <>
        <h2 class="font-display mb-3 mt-[26px] text-[20px] font-extrabold">{nextStage} · coming up</h2>
        <div class="grid gap-[15px]" style="grid-template-columns:repeat(auto-fill,minmax(300px,1fr))">
          {upcoming.map((m) => {
            const h = getTeam(m.homeTeamId), a = getTeam(m.awayTeamId);
            const f = fc(h.id, a.id);
            return (
              <a href={`/matches/${matchSlug(m)}`} class="kb-card-hover block rounded-[16px] border p-[17px]" style="background:#fff;border-color:#e9e1d2">
                <div class="flex items-center justify-between">
                  <span class="text-[11px] font-bold uppercase tracking-[.6px]" style="color:#a59a85">{dateLabel(m.date)} · {stageLabel[m.stage]}</span>
                  <span class="text-[11px]" style="color:#b3a890">{m.venue ?? ''}</span>
                </div>
                <div class="mb-1 mt-[13px] flex items-center gap-[9px]"><Flag team={h.id} w={34} /><b class="text-[16px]">{h.name}</b></div>
                <div class="flex items-center gap-[9px]"><Flag team={a.id} w={34} /><b class="text-[16px]">{a.name}</b></div>
                <div class="mt-[13px] flex h-[10px] overflow-hidden rounded-[6px]">
                  <span style={`width:${f.win}%;background:var(--color-royal)`}></span><span style={`width:${f.draw}%;background:#c7bda0`}></span><span style={`width:${f.lose}%;background:#2b2e36`}></span>
                </div>
                <div class="mt-2 text-[13px] font-bold" style="color:#6f6655">{f.line} · tap to vote</div>
              </a>
            );
          })}
        </div>
      </>
    )}

    <h2 class="font-display mb-3 mt-7 text-[20px] font-extrabold">Recent results</h2>
    <div class="flex flex-col gap-2.5">
      {recent.map((m) => {
        const h = getTeam(m.homeTeamId), a = getTeam(m.awayTeamId);
        return (
          <a href={`/matches/${matchSlug(m)}`} class="kb-card-hover flex items-center justify-between rounded-[13px] border px-4 py-[13px]" style="background:#fff;border-color:#e9e1d2">
            <div class="flex flex-1 items-center gap-[9px]"><Flag team={h.id} w={30} /><b class="text-[15px]">{h.name}</b></div>
            <div class="font-display flex-none px-[14px] text-[18px] font-black">{m.homeScore}–{m.awayScore}</div>
            <div class="flex flex-1 items-center justify-end gap-[9px]"><b class="text-[15px]">{a.name}</b><Flag team={a.id} w={30} /></div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
