---
// Player detail — built from claude-design Kickabout.dc.html (#/player). Avatar +
// name + position·team·club, KPI cards (career international totals + tiers), and
// the player's real WORLD CUP match log (bridged to AF stats via the AF id in the
// photo URL). All from cached data — no live API calls.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { getPlayerTiers, getPlayerWcStats, afPlayerId } from '../../lib/warehouse';
import Avatar from '../../components/analysis/Avatar.astro';
import Flag from '../../components/Flag.astro';

export function getStaticPaths() {
  return provider.getAllPlayers().map((p) => ({ params: { id: p.id }, props: { p } }));
}

const { p } = Astro.props;
const team = provider.getTeam(p.teamId)!;
const tiers = getPlayerTiers(p.id);
const wc = getPlayerWcStats(afPlayerId(tiers?.photo));

const posName: Record<string, string> = { GK: 'Goalkeeper', DF: 'Defender', MF: 'Midfielder', FW: 'Forward' };
const posColor: Record<string, string> = { GK: '#e0a200', DF: '#1f3fbf', MF: '#138a5e', FW: '#b23b2e' };

// KPI cards — career international totals + our tiers.
const kpis: { value: string; label: string }[] = [
  { value: String(p.caps), label: 'Caps' },
  { value: String(p.goals), label: 'Int’l goals' },
  { value: p.age ? `${p.age}` : '—', label: 'Age' },
  { value: tiers?.playerTier ?? '—', label: 'Player tier' },
];

const stageLabel: Record<string, string> = { group: 'Group', r32: 'R32', r16: 'R16', qf: 'QF', sf: 'SF', final: 'Final', third_place: '3rd' };
const fmtDate = (iso: string) => (iso ? new Intl.DateTimeFormat('en', { day: 'numeric', month: 'short' }).format(new Date(iso)) : '');
const opponentOf = (m: { homeId: string; awayId: string }) => (m.homeId === p.teamId ? m.awayId : m.homeId);

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Person', name: p.name,
  jobTitle: posName[p.pos] ?? p.pos,
  ...(p.club ? { affiliation: { '@type': 'SportsTeam', name: p.club } } : {}),
};
---

<BaseLayout
  title={`${p.name} — ${team.name} | World Cup 2026 | Kickabout`}
  description={`${p.name}: ${posName[p.pos] ?? p.pos} for ${team.name} at the 2026 World Cup. ${p.caps} caps, ${p.goals} international goals, ${p.club ?? ''}. Tournament match log and stats.`}
  active="teams"
  canonical={`/players/${p.id}/`}
  jsonLd={jsonLd}
>
  <div class="kb-route">
    <a href={`/teams/${team.id}/`} class="text-[13.5px] font-bold" style="color:#a59a85">← {team.name} squad</a>

    {/* header */}
    <div class="mt-4 flex items-center gap-[18px]">
      <Avatar name={p.name} position={p.pos} photo={tiers?.photo ?? null} size={84} />
      <div>
        <h1 class="font-display text-[32px] font-black tracking-[-.8px]">{p.name}</h1>
        <div class="mt-[3px] flex flex-wrap items-center gap-1.5 text-[14.5px]" style="color:#6f6655">
          <span>{posName[p.pos] ?? p.pos}</span><span>·</span>
          <a href={`/teams/${team.id}/`} class="inline-flex items-center gap-1.5 font-bold" style="color:var(--color-royal)"><Flag team={team.id} w={20} /> {team.name}</a>
          {p.club && <><span>·</span><span>{p.club}</span></>}
          {tiers?.clubTier && (
            <span class="rounded-full px-2 py-[2px] text-[11px] font-extrabold" style="color:#6f6655;background:#ece4d4">{tiers.clubTier} club</span>
          )}
        </div>
      </div>
    </div>

    {/* KPIs */}
    <div class="mt-5 grid gap-3" style="grid-template-columns:repeat(auto-fit,minmax(120px,1fr))">
      {kpis.map((k) => (
        <div class="rounded-[14px] border p-4" style="background:#fff;border-color:#e9e1d2">
          <div class="font-display text-[28px] font-black tracking-[-.5px]">{k.value}</div>
          <div class="mt-px text-[12.5px] font-semibold" style="color:#6f6655">{k.label}</div>
        </div>
      ))}
    </div>

    {/* WORLD CUP match log — real per-match stats for this tournament */}
    {wc && wc.matches.length > 0 ? (
      <>
        <div class="mt-7 mb-3 flex items-baseline justify-between">
          <h2 class="font-display text-[20px] font-extrabold">This World Cup</h2>
          <span class="text-[13px] font-semibold" style="color:#a59a85">{wc.apps} app{wc.apps === 1 ? '' : 's'} · {wc.goals}G · {wc.assists}A · {wc.mins} min</span>
        </div>
        <div class="overflow-hidden rounded-[16px] border" style="background:#fff;border-color:#e9e1d2">
          <div class="flex items-center px-4 py-2.5 text-[11px] font-bold uppercase tracking-wide" style="background:#faf6ee;border-bottom:1px solid #f1ebdf;color:#a59a85">
            <span class="flex-1">Match</span>
            <span class="w-12 text-center">Min</span>
            <span class="w-10 text-center">G/A</span>
            <span class="w-12 text-center">Rating</span>
          </div>
          {wc.matches.map((m) => {
            const opp = provider.getTeam(opponentOf(m));
            return (
              <a href={`/matches/${m.homeId}-vs-${m.awayId}-${m.stage}/`} class="flex items-center border-b px-4 py-2.5 text-[13px] last:border-b-0" style="border-color:#f4eee1">
                <span class="flex flex-1 items-center gap-2">
                  {opp && <Flag team={opp.id} w={22} />}
                  <b class="text-[13.5px]">{stageLabel[m.stage] ?? m.stage} v {opp?.shortCode ?? '—'}</b>
                  <span class="text-[11.5px]" style="color:#a59a85">{fmtDate(m.date)}</span>
                </span>
                <span class="w-12 text-center tabular-nums" style="color:#6f6655">{m.minutes ?? 0}'</span>
                <span class="w-10 text-center font-bold tabular-nums">{m.goals ?? 0}/{m.assists ?? 0}</span>
                <span class="font-display w-12 text-center font-extrabold tabular-nums" style="color:var(--color-royal)">{m.rating ?? '–'}</span>
              </a>
            );
          })}
        </div>
        <p class="mt-2 text-[12px]" style="color:#a59a85">Per-match data from API-Football. Caps and international goals are career totals.</p>
      </>
    ) : (
      <div class="mt-5 rounded-[12px] border border-l-4 p-4 text-[14px]" style="background:#fff;border-color:#e9e1d2;border-left-color:var(--color-gold);color:#6f6655">
        No World Cup minutes logged yet — match-by-match stats appear here once {p.name.split(' ').slice(-1)[0]} features. Figures above are career international totals.
      </div>
    )}
  </div>
</BaseLayout>
