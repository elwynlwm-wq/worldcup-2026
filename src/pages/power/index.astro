---
// Power ranking — all 48 teams by adjusted rating. Light Kickabout style.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import Flag from '../../components/Flag.astro';

const teams = provider.getTeams().slice().sort((a, b) => b.adjRating - a.adjRating);
---

<BaseLayout
  title="Power Ranking — World Cup 2026 | Kickabout"
  description="All 48 teams ranked by our power score — a blend of rating, world ranking, tournament form and squad strength. Higher is stronger."
  active="teams"
  canonical="/power/"
>
  <div class="kb-route">
    <h1 class="font-display text-[34px] font-black tracking-tight">Power ranking</h1>
    <p class="mt-0.5 mb-5 text-[15px]" style="color:var(--color-ink-2)">
      All 48 teams, strongest first. Our <b style="color:var(--color-ink)">power score</b> blends each team's
      rating, world ranking, how they've played here and squad firepower.
    </p>

    <div class="overflow-hidden rounded-[16px] border" style="background:var(--color-surface);border-color:var(--color-line-2)">
      {teams.map((t, i) => (
        <a href={`/teams/${t.id}/`} class="flex items-center gap-3 border-b px-4 py-3 transition hover:bg-[var(--color-surface-2)]" style="border-color:var(--color-surface-3)">
          <span class="font-display w-7 text-right text-[15px] font-black" style="color:var(--color-ink-4)">{i + 1}</span>
          <Flag team={t.id} w={28} />
          <b class="flex-1 text-[14.5px]">{t.name}</b>
          <span class="hidden text-[12px] sm:inline" style="color:var(--color-ink-3)">Elo {t.elo} · #{t.fifaRank} · Grp {t.groupLetter}</span>
          <span class="font-display ml-3 text-[18px] font-black" style="color:var(--color-royal)">{t.strength}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
