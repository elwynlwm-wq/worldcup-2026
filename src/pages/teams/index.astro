---
// Teams index — ported from the design (teams section). 48 cards, each with a
// two-tone colour band header. Grouped by group letter for a tidy overview.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { provider } from '../../lib/provider';
import { teamColors } from '../../data/teamColors';

// Card header = generated banner faded into the card (style E), over a team-colour
// wash that also serves as the fallback when a team has no banner yet. Banners
// lazy-load (offscreen cards don't fetch) to protect the listing's load.
const wash = (id: string) => {
  const { c1, c2 } = teamColors(id);
  return `linear-gradient(160deg, ${c1} 0%, ${c1} 35%, ${c2} 120%)`;
};

const groups = provider.getGroups();
const getTeam = (id: string) => provider.getTeam(id)!;

const statusStyle: Record<string, { color: string; bg: string; label: string }> = {
  winner: { color: '#0b6b3a', bg: 'rgba(19,138,94,.14)', label: 'Group winners' },
  runner_up: { color: '#0b6b3a', bg: 'rgba(19,138,94,.14)', label: 'Through (2nd)' },
  best_third: { color: '#0b6b3a', bg: 'rgba(19,138,94,.14)', label: 'Through (3rd)' },
  contention: { color: '#8a6d10', bg: 'rgba(243,181,10,.18)', label: 'Still alive' },
  eliminated: { color: '#9d2730', bg: 'rgba(157,39,48,.12)', label: 'Eliminated' },
};
---

<BaseLayout
  title="Teams — World Cup 2026 | Kickabout"
  description="All 48 nations at the 2026 World Cup, by group. Tap a team for squad, stats, power ranking and the players to watch."
  active="teams"
  canonical="/teams/"
>
  <div class="kb-route">
    <h1 class="font-display text-[34px] font-black tracking-tight">Teams</h1>
    <p class="mt-0.5 mb-4 text-[15px]" style="color:var(--color-ink-2)">
      All 48 nations, by group. Tap a team to dive into the squad.
    </p>

    {groups.map((g) => (
      <div class="mb-6">
        <h2 class="font-display mb-2.5 text-[15px] font-extrabold" style="color:var(--color-ink-2)">{g.name}</h2>
        <div class="grid gap-3" style="grid-template-columns:repeat(auto-fill,minmax(215px,1fr))">
          {g.standings.map((s) => {
            const t = getTeam(s.teamId);
            const st = statusStyle[t.status] ?? statusStyle.contention;
            return (
              <a href={`/teams/${t.id}/`} class="kb-card-hover block overflow-hidden rounded-[15px] border" style="background:var(--color-surface);border-color:var(--color-line-2)">
                <div class="relative" style={`height:74px;background:${wash(t.id)}`}>
                  <img
                    src={`/banners/${t.id}.png`}
                    alt=""
                    loading="lazy"
                    class="h-full w-full object-cover"
                    style="opacity:.85;-webkit-mask-image:linear-gradient(180deg,#000 55%,transparent);mask-image:linear-gradient(180deg,#000 55%,transparent)"
                    onerror="this.remove()"
                  />
                </div>
                <div class="px-4 pt-2 pb-4">
                  <b class="block text-[15.5px] tracking-tight">{t.name}</b>
                  <div class="mt-0.5 text-xs" style="color:var(--color-ink-3)">Group {t.groupLetter} · {t.confederation}</div>
                  <div class="mt-2.5 inline-block rounded-full px-2.5 py-[3px] text-[11px] font-extrabold" style={`color:${st.color};background:${st.bg}`}>{st.label}</div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
